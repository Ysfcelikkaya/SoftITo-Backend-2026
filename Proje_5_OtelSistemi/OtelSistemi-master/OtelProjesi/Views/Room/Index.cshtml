@{
    ViewData["Title"] = "Oda Yönetimi";
}

<div class="container mt-4">
    <h2>Oda Yönetim Paneli (Admin)</h2>
    <hr />
    
    <button type="button" class="btn btn-success mb-3" id="btnAddRoom">
        + Yeni Oda Ekle
    </button>

    <input type="hidden" id="urlRoomData" value="/Room/RoomList" />

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Oda No</th>
                <th>Oda Tipi</th>
                <th>Fiyat</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody id="table_data">
            </tbody>
    </table>
</div>

<div class="modal fade" id="RoomModal" tabindex="-1" role="dialog" aria-labelledby="roomHeading" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="roomHeading">Oda İşlemleri</h5>
                <button type="button" class="close" onclick="HideModalPopUp()" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form>
                    <input type="hidden" id="RoomId" />

                    <div class="form-group mb-2">
                        <label for="RoomNumber">Oda Numarası</label>
                        <input type="number" class="form-control" id="RoomNumber" placeholder="Örn: 101" />
                    </div>
                    <div class="form-group mb-2">
                        <label for="Type">Oda Tipi</label>
                        <input type="text" class="form-control" id="Type" placeholder="Örn: Suit, Kral Dairesi" />
                    </div>
                    <div class="form-group mb-3">
                        <label for="Price">Günlük Fiyat (₺)</label>
                        <input type="number" class="form-control" id="Price" placeholder="Örn: 1500" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" id="AddRoomBtn" onclick="AddRoom()">Kaydet</button>
                <button type="button" class="btn btn-primary" id="btnUpdate" onclick="UpdateRoom()" style="display:none;">Güncelle</button>
                <button type="button" class="btn btn-secondary" onclick="HideModalPopUp()">Kapat</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/room.js"></script>
}
