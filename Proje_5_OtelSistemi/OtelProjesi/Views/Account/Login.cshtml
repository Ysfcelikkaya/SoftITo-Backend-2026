@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - Grand Hotel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: url('https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=2070&auto=format&fit=crop') no-repeat center center fixed;
            background-size: cover;
        }
        .overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(15, 23, 42, 0.85); 
        }
        .login-card {
            background: #fff; border-radius: 15px; box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            position: relative; z-index: 10;
        }
        .brand-text { font-family: 'Playfair Display', serif; color: #d4af37; letter-spacing: 1px; }
        .btn-gold { background-color: #d4af37; color: #fff; border: none; transition: 0.3s; }
        .btn-gold:hover { background-color: #b5952f; color: #fff; }
        .input-group-text { background-color: transparent; border-right: none; color: #94a3b8; }
        .form-control { border-left: none; }
        .form-control:focus { box-shadow: none; border-color: #d4af37; }
    </style>
</head>
<body>
    <div class="overlay"></div>
    <div class="container d-flex justify-content-center align-items-center" style="height:100vh;">
        <div class="card login-card p-5" style="width: 420px;">
            <div class="text-center mb-4">
                <i class="bi bi-buildings-fill" style="font-size: 3rem; color: #d4af37;"></i>
                <h2 class="brand-text mt-2 mb-0">GRAND HOTEL</h2>
                <small class="text-muted">Yönetim Paneli</small>
            </div>

            <form method="post" asp-controller="Account" asp-action="Login">
                <div class="mb-4">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input name="Username" class="form-control" type="text" placeholder="Kullanıcı Adı" />
                    </div>
                </div>

                <div class="mb-4">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input name="Password" class="form-control" type="password" placeholder="Şifre" />
                    </div>
                </div>

                <button type="submit" class="btn btn-gold w-100 fw-bold py-2 mb-3 shadow-sm">
                    Giriş Yap
                </button>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger text-center small py-2">
                        <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.ErrorMessage
                    </div>
                }

                <div class="text-center mt-3">
                    <span class="text-muted" style="font-size: 0.9rem;">Personel kaydınız yok mu?</span><br/>
                    <a href="/Account/Register" class="text-decoration-none fw-bold" style="color: #0f172a;">Kayıt Ol</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>