<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Grand Otel Yönetimi</title>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">


    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

 
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
            body {
                font-family: 'Poppins', sans-serif;
                background-color: #f4f7f6; 
            }

            .sidebar {
                width: 280px;
                height: 100vh;
                position: fixed;
                top: 0;
                left: 0;
                background: #0f172a;
                color: #fff;
                padding-top: 20px;
                box-shadow: 4px 0 15px rgba(0,0,0,0.1);
                z-index: 1000;
            }

            .sidebar-brand {
                font-family: 'Playfair Display', serif; 
                font-size: 1.6rem;
                text-align: center;
                padding: 10px 20px 30px;
                color: #d4af37; 
                border-bottom: 1px solid rgba(255, 255, 255, 0.05);
                margin-bottom: 20px;
                letter-spacing: 1px;
            }

            .sidebar a {
                display: flex;
                align-items: center;
                color: #94a3b8;
                padding: 16px 30px;
                text-decoration: none;
                transition: all 0.3s ease;
                font-size: 1rem;
            }

            .sidebar a:hover, .sidebar a.active {
                background: rgba(212, 175, 55, 0.1);
                color: #d4af37;
                border-left: 5px solid #d4af37;
            }

            .sidebar a i {
                font-size: 1.3rem;
                margin-right: 15px;
            }

            .topbar {
                height: 75px;
                background: #fff;
                margin-left: 280px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 40px;
                box-shadow: 0 4px 20px rgba(0,0,0,0.03);
                position: sticky;
                top: 0;
                z-index: 999;
            }

            .content {
                margin-left: 280px;
                padding: 40px;
                min-height: calc(100vh - 135px);
            }

            .footer {
                margin-left: 280px;
                background: #fff;
                padding: 20px;
                text-align: center;
                border-top: 1px solid #eaeaea;
                color: #94a3b8;
                font-size: 0.9rem;
            }
    </style>
</head>

<body>

    <div class="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-buildings text-white mb-2" style="font-size: 2rem;"></i><br />
            GRAND HOTEL
        </div>

        <a asp-area="" asp-controller="Home" asp-action="Index">
            <i class="bi bi-grid-1x2"></i> Dashboard
        </a>

        <a asp-area="" asp-controller="Reservation" asp-action="Index">
            <i class="bi bi-calendar2-check"></i> Rezervasyonlar
        </a>

        <a asp-area="" asp-controller="Room" asp-action="Index">
            <i class="bi bi-door-open"></i> Oda Yönetimi
        </a>

        <a asp-area="" asp-controller="User" asp-action="Index">
            <i class="bi bi-people"></i> Kullanıcı Yönetimi
        </a>

        <div style="position: absolute; bottom: 30px; width: 100%;">
            <hr style="border-color: rgba(255,255,255,0.05); margin: 0 30px 20px;">
            <a href="/Account/Login" class="text-danger" style="border:none;">
                <i class="bi bi-box-arrow-left"></i> Çıkış Yap
            </a>
        </div>
    </div>

    <div class="topbar">
        <div>

            <h4 class="m-0 text-dark fw-bold">@ViewData["Title"]</h4>
        </div>

        <div class="d-flex align-items-center gap-4">
            <button class="btn btn-light position-relative rounded-circle border-0 bg-transparent">
                <i class="bi bi-bell fs-5 text-secondary"></i>
                <span class="position-absolute top-25 start-75 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
            </button>

            <div class="dropdown">
                <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-2 border-0 bg-transparent" type="button" data-bs-toggle="dropdown">
                    <img src="https://ui-avatars.com/api/?name=Resepsiyon&background=d4af37&color=fff" class="rounded-circle shadow-sm" width="38" height="38" alt="Admin">
                    <div class="text-start ms-1 d-none d-md-block">
                        <span class="fw-bold text-dark d-block" style="font-size:0.9rem;">Resepsiyon</span>
                        <span class="text-muted d-block" style="font-size:0.75rem;">Aktif Vardiya</span>
                    </div>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3" style="border-radius: 10px;">
                    <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person me-2"></i>Profil</a></li>
                    <li><a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-2"></i>Otel Ayarları</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item py-2 text-danger fw-bold" href="/Account/Login"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        &copy; 2026 - Grand Hotel Yönetim Sistemi - Tüm Hakları Saklıdır.
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>