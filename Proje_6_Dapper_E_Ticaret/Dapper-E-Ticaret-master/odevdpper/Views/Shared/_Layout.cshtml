<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Dapper E-Commerce</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand" href="/">E-Commerce</a>

            <div class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link text-white" href="/Home/Index">Dashboard</a>
                </li>
                <li class="nav-item">
                <a class="nav-link text-white" href="/Category/Index">Categories</a>
                </li>
                    <li class="nav-item">
                <a class="nav-link text-white" href="/Product/Index">Products</a>
                </li>
                        <li class="nav-item">
                <a class="nav-link text-white" href="/Customer/Index">Customers</a>
                </li>
                            <li class="nav-item">
                <a class="nav-link text-white" href="/Order/Index">Orders</a>
                </li>
                                <li class="nav-item">
                <a class="nav-link text-red" href="/Report/OrderReport">Order Report</a>
                </li>

                @if (Context.Session.GetString("FullName") != null)
                {
                    <li class="nav-item">
                        <span class="nav-link text-white">
                            Hello @Context.Session.GetString("FullName")
                        </span>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Auth/Logout">Logout</a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Auth/Login">Login</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Auth/Register">Register</a>
                    </li>
                }
@*              <a class="nav-link text-white" href="/Home/Index">Dashboard</a>
                <a class="nav-link text-white" href="/Category/Index">Categories</a>
                <a class="nav-link text-white" href="/Product/Index">Products</a>
                <a class="nav-link text-white" href="/Customer/Index">Customers</a>
                <a class="nav-link text-white" href="/Order/Index">Orders</a>
                <a class="nav-link text-red" href="/Report/OrderReport">Order Report</a> *@

            </div>

        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

</body>
</html>