@model IEnumerable<DapperECommerce.Models.OrderReport>

<h2>Order Report</h2>

<form method="get" class="mb-3">

    <select name="customerId" class="form-control w-25 d-inline">
        <option value="">All Customers</option>
        @foreach (var c in ViewBag.Customers)
        {
            <option value="@c.CustomerId">@c.FullName</option>
        }
    </select>

    <select name="productId" class="form-control w-25 d-inline">
        <option value="">All Products</option>
        @foreach (var p in ViewBag.Products)
        {
            <option value="@p.ProductId">@p.ProductName</option>
        }
    </select>


    <select name="categoryId" class="form-control w-25 d-inline">
        <option value="">All Categories</option>
        @foreach (var cat in ViewBag.Categories)
        {
            <option value="@cat.CategoryId">@cat.CategoryName</option>
        }
    </select>


    <select name="sortType" class="form-control w-50 d-inline">
        <option value="1">Newest First</option>
        <option value="2">Oldest First</option>
        <option value="3">Quantity High → Low</option>
        <option value="4">Quantity Low → High</option>
    </select>

    <button type="submit" class="btn btn-primary">Filter</button>
</form>

<table class="table table-bordered table-striped">

    <thead>
        <tr>
            <th>Customer</th>
            <th>Product</th>
            <th>Category</th>
            <th>Quantity</th>
            <th>Date</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.ProductName</td>
                <td>@item.CategoryName</td>
                <td>@item.Quantity</td>
                <td>@item.OrderDate</td>
            </tr>
        }
    </tbody>

</table>