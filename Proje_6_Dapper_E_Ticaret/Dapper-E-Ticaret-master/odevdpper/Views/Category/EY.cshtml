@model DapperECommerce.Models.Category

@{
    ViewData["Title"] = "Category Form";
}

<h2>Category Form</h2>

<form method="post" asp-action="EY">

    <input type="hidden" asp-for="CategoryId" />

    <div class="form-group">
        <label>Category Name</label>
        <input type="text" asp-for="CategoryName" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-success">Save</button>
    <a href="/Category/Index" class="btn btn-secondary">Back</a>

</form>