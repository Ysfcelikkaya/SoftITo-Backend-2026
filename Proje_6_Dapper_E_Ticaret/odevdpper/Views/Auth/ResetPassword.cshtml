<h2>Reset Password</h2>

<form method="post">

    <input name="email"
           class="form-control mb-2"
           placeholder="Email" />

    <input name="code"
           class="form-control mb-2"
           placeholder="Reset Code" />

    <input name="password"
           type="password"
           class="form-control mb-2"
           placeholder="New Password" />

    <button class="btn btn-success">
        Reset Password
    </button>

</form>