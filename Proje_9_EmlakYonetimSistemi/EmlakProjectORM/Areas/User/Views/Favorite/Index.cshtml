@model IEnumerable<EmlakProjectORM.Models.Favorite>

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-6">
            <h2 class="text-primary">Favori İlanlar</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Favorite" asp-action="Create" class="btn btn-primary">+ Yeni Favori Ekle</a>
        </div>
    </div>
    
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Müşteri Adı</th>
                <th>Beğendiği İlan</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AppUser.FullName</td>
                    <td>@item.Property.Title</td>
                    <td>
                        <a asp-controller="Favorite" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>