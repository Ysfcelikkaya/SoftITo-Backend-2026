@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <title>Admin Girişi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-dark d-flex align-items-center justify-content-center" style="height: 100vh;">
    
    <div class="card text-white shadow-lg p-4" style="width: 25rem; background-color:#2c3e50;">
        <h3 class="text-center mb-4 text-warning">Yönetici Paneli</h3>
        
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center">@ViewBag.Error</div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label">Kullanıcı Adı</label>
                <input type="text" name="username" class="form-control" placeholder="Admin kullanıcı adınız" required />
            </div>
            <div class="mb-4">
                <label class="form-label">Şifre</label>
                <input type="password" name="password" class="form-control" placeholder="*****" required />
            </div>
            <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold">Giriş Yap</button>
            <a href="/" class="btn btn-outline-light w-100 mt-3">Seçim Ekranına Dön</a>
        </form>
    </div>

</body>
</html>