@model EmlakProjectORM.Models.AppUser
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <title>Müşteri Kayıt Ol</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">
    
    <div class="card border-0 shadow-lg p-4" style="width: 25rem; border-top: 5px solid #198754 !important;">
        <h3 class="text-center mb-4 text-success fw-bold">Yeni Kayıt</h3>
        
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center">@ViewBag.Error</div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label text-muted">Ad Soyad</label>
                <input asp-for="FullName" class="form-control" placeholder="Adınız Soyadınız" required />
            </div>
            <div class="mb-3">
                <label class="form-label text-muted">Email Adresi</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="ornek@mail.com" required />
            </div>
            <div class="mb-3">
                <label class="form-label text-muted">Şifre</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="*****" required />
            </div>
@*             <div class="mb-4">
                <label class="form-label text-muted">Telefon Numaranız</label>
                <input asp-for="PhoneNumber" type="tel" class="form-control" placeholder="05XX XXX XX XX" required />
            </div> *@
            <button type="submit" class="btn btn-success btn-lg w-100 fw-bold">Kayıt Ol</button>
            <a href="/User/Login/Index" class="btn btn-outline-secondary w-100 mt-3">Zaten üye misin? Giriş Yap</a>
        </form>
    </div>

</body>
</html>