@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <title>Müşteri Girişi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">

    <div class="card border-0 shadow-lg p-4" style="width: 25rem; border-top: 5px solid #0d6efd !important;">
        <h3 class="text-center mb-4 text-primary fw-bold">Müşteri Girişi</h3>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center">@ViewBag.Error</div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label text-muted">Email Adresi</label>
                <input type="email" name="email" class="form-control" placeholder="ornek@mail.com" required />
            </div>
            <div class="mb-4">
                <label class="form-label text-muted">Şifre</label>
                <input type="password" name="password" class="form-control" placeholder="*****" required />
            </div>
            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">Giriş Yap</button>
            <a href="/User/Register/Index" class="btn btn-link w-100 mt-2">Hesabın yok mu? Kayıt Ol</a>
            <a href="/" class="btn btn-outline-secondary w-100 mt-3">Seçim Ekranına Dön</a>
        </form>
    </div>

</body>
</html>