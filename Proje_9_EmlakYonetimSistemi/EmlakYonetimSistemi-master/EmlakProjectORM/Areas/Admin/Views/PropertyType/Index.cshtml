@model IEnumerable<EmlakProjectORM.Models.PropertyType>

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-6">
            <h2>Emlak Tipleri</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="PropertyType" asp-action="Create" class="btn btn-primary">+ Yeni Emlak Tipi</a>
        </div>
    </div>
    
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Emlak Tipi</th>
                <th>Açıklama</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.TypeName</td>
                    <td>@item.Description</td>
                    <td>
                        <a asp-controller="PropertyType" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                        <a asp-controller="PropertyType" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>