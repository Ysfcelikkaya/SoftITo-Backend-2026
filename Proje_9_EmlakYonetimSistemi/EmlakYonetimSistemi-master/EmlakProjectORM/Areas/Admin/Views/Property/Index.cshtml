@model IEnumerable<EmlakProjectORM.Models.Property>

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-6">
            <h2>İlan Listesi</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Property" asp-action="Crup" class="btn btn-primary">
                + Yeni İlan Ekle
            </a>
        </div>
    </div>

    <table id="exportTable" class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Fotoğraf</th>
                <th>İlan Başlığı</th>
                <th>Emlak Tipi</th>
                <th>Fiyat</th>
                <th>Oda / m²</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @if (item.Photo != null)
                        {
                            <img src="@item.Photo" width="80" style="border-radius:5px;" />
                        }
                        else
                        {
                            <span>Görsel Yok</span>
                        }
                    </td>
                    <td class="align-middle">@item.Title</td>
                    <td class="align-middle">@item.PropertyType.TypeName</td>
                    <td class="align-middle">@item.Price ₺</td>
                    <td class="align-middle">@item.Rooms Oda / @item.SquareMeters m²</td>
                    <td class="align-middle">
                        <a asp-controller="Property" asp-action="Crup" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Güncelle</a>
                        <a asp-controller="Property" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

    <script>
        $(document).ready(function() {
        $('#exportTable').DataTable({
        dom: 'Bfrtip',
        buttons: [
        { extend: 'excelHtml5', text: 'Excel İndir', className: 'btn btn-success btn-sm' },
        { extend: 'pdfHtml5', text: 'PDF İndir', className: 'btn btn-danger btn-sm' }
        ],
        language: {
        url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json'
        }
        });
        });
    </script>
}