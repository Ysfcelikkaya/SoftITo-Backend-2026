@model HospitalAppMvc.Models.DashboardViewModel
@{
    ViewData["Title"] = "Ana Panel";
}

<div class="container mt-4">
    <!-- Üst Başlık -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-0">Hastaneye Hoş Geldiniz 👋</h2>
            <p class="text-muted mt-1">Sistemdeki genel durumu ve kısayolları aşağıdan takip edebilirsiniz.</p>
        </div>
        <div>
            <span class="badge bg-primary text-white p-2 rounded-3 shadow-sm">
                <i class="bi bi-clock-history"></i> @DateTime.Now.ToString("dd MMMM yyyy - HH:mm")
            </span>
        </div>
    </div>

    <!-- YETKİ KONTROLÜ: Sadece Admin ve Doktorlar istatistikleri görebilir! -->
    @if (User.IsInRole("Admin") || User.IsInRole("Doctor") || User.IsInRole("Doktor"))
    {
        <div class="row g-4 mb-5">
            <!-- Toplam Hasta Kartı -->
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, #3A8DFF 0%, #0056b3 100%);">
                    <div class="card-body p-4 text-white">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold opacity-75 mb-0">TOPLAM HASTA</h6>
                            <i class="bi bi-people-fill fs-3 opacity-50"></i>
                        </div>
                        <h2 class="display-5 fw-bold mb-0">@Model.TotalPatients</h2>
                        <p class="mb-0 mt-2 opacity-75" style="font-size: 13px;"><i class="bi bi-arrow-up-right-circle"></i> Sistemde kayıtlı hastalar</p>
                    </div>
                </div>
            </div>

            <!-- Toplam Doktor Kartı -->
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, #10b981 0%, #047857 100%);">
                    <div class="card-body p-4 text-white">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold opacity-75 mb-0">TOPLAM DOKTOR</h6>
                            <i class="bi bi-heart-pulse-fill fs-3 opacity-50"></i>
                        </div>
                        <h2 class="display-5 fw-bold mb-0">@Model.TotalDoctors</h2>
                        <p class="mb-0 mt-2 opacity-75" style="font-size: 13px;"><i class="bi bi-check-circle"></i> Aktif görev yapanlar</p>
                    </div>
                </div>
            </div>

            <!-- Toplam Randevu Kartı -->
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, #f59e0b 0%, #b45309 100%);">
                    <div class="card-body p-4 text-white">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold opacity-75 mb-0">TÜM RANDEVULAR</h6>
                            <i class="bi bi-calendar-check-fill fs-3 opacity-50"></i>
                        </div>
                        <h2 class="display-5 fw-bold mb-0">@Model.TotalAppointments</h2>
                        <p class="mb-0 mt-2 opacity-75" style="font-size: 13px;"><i class="bi bi-graph-up"></i> Geçmiş ve gelecek randevular</p>
                    </div>
                </div>
            </div>

            <!-- Toplam Ciro Kartı -->
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, #ef4444 0%, #991b1b 100%);">
                    <div class="card-body p-4 text-white">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold opacity-75 mb-0">TOPLAM GELİR (CİRO)</h6>
                            <i class="bi bi-cash-coin fs-3 opacity-50"></i>
                        </div>
                        <h2 class="display-6 fw-bold mb-0">₺@Model.TotalRevenue.ToString("N2")</h2>
                        <p class="mb-0 mt-2 opacity-75" style="font-size: 13px;"><i class="bi bi-wallet2"></i> Kesilen faturalar toplamı</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- HASTA GİRİŞ YAPTIYSA ONA ÖZEL ŞIK BİR KARŞILAMA KARTI GÖSTERİYORUZ -->
        <div class="alert border-0 shadow-sm rounded-4 mb-5 p-4" style="background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%); color: #0369a1;">
            <div class="d-flex align-items-center">
                <i class="bi bi-robot me-3" style="font-size: 3rem;"></i>
                <div>
                    <h4 class="fw-bold mb-1">Akıllı Semptom Kontrolüne Hazır mısınız?</h4>
                    <p class="mb-0 opacity-75">Sağ alt köşedeki <strong>Yapay Zeka Botuna</strong> tıklayarak şikayetlerinizi anlatabilir ve hangi polikliniğe gitmeniz gerektiğini saniyeler içinde öğrenebilirsiniz!</p>
                </div>
            </div>
        </div>
    }

    <!-- Hızlı İşlemler Paneli (Kısayollar) -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h5 class="fw-bold text-dark border-bottom pb-3 mb-4"><i class="bi bi-lightning-charge-fill text-warning"></i> Hızlı İşlemler Kısayolu</h5>

            <div class="row text-center g-3">

                <!-- Randevular (Bunu herkes görebilir) -->
                <div class="col-md-2">
                    <a asp-controller="Appointments" asp-action="Index" class="btn btn-light border w-100 py-3 rounded-4 shadow-sm hover-effect">
                        <i class="bi bi-calendar-check fs-2 text-primary"></i>
                        <div class="fw-bold mt-2 text-dark">Randevularım</div>
                    </a>
                </div>

                <!-- YENİ EKLENEN HASTA KISAYOLU BURADA -->
                <div class="col-md-2">
                    <a asp-controller="MedicalRecords" asp-action="Index" class="btn btn-light border w-100 py-3 rounded-4 shadow-sm hover-effect">
                        <i class="bi bi-file-earmark-pdf-fill fs-2 text-danger"></i>
                        <div class="fw-bold mt-2 text-dark">Raporlarım</div>
                    </a>
                </div>

                <!-- Tıbbi Kayıtlar ve Yatış (Sadece Doktor ve Admin) -->
                @if (User.IsInRole("Admin") || User.IsInRole("Doctor") || User.IsInRole("Doktor"))
                {
                    <div class="col-md-2">
                        <a asp-controller="Admissions" asp-action="Index" class="btn btn-light border w-100 py-3 rounded-4 shadow-sm hover-effect">
                            <i class="bi bi-hospital fs-2 text-info"></i>
                            <div class="fw-bold mt-2 text-dark">Yatış İşlemleri</div>
                        </a>
                    </div>
                }

                <!-- Faturalar (Sadece Admin) -->
                @if (User.IsInRole("Admin"))
                {
                    <div class="col-md-2">
                        <a asp-controller="Invoices" asp-action="Index" class="btn btn-light border w-100 py-3 rounded-4 shadow-sm hover-effect">
                            <i class="bi bi-receipt-cutoff fs-2 text-success"></i>
                            <div class="fw-bold mt-2 text-dark">Faturalar</div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .hover-effect {
        transition: all 0.3s ease;
    }

        .hover-effect:hover {
            transform: translateY(-5px);
            background-color: #f8f9fa !important;
            border-color: #d1d5db !important;
        }
</style>