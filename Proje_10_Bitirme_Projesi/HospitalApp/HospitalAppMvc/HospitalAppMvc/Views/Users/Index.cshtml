@model IEnumerable<HospitalAppMvc.Models.UserViewModel>

<div class="container mt-5">

    <!-- HATA VEYA BAŞARI MESAJI -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show fw-bold shadow-sm" role="alert">
            ⚠️ @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-bold shadow-sm" role="alert">
            ✅ @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-person-lines-fill text-secondary me-2"></i> Sistem Kullanıcıları</h2>
        <a asp-action="Create" class="btn btn-secondary fw-bold px-4 rounded-pill shadow-sm">
            <i class="bi bi-person-plus-fill"></i> Yeni Kullanıcı Ekle
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Kullanıcı Adı</th>
                        <th>E-Posta</th>
                        <th>Rol / Yetki</th>
                        <th>Durum</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-muted">#@user.Id</td>
                            <td class="fw-bold">@user.Username</td>
                            <td>@user.Email</td>
                            <td>
                                @if (user.RoleId == 1)
                                {
                                    <span class="badge bg-danger">Yönetici (Admin)</span>
                                }
                                else if (user.RoleId == 2)
                                {

                                    <span class="badge bg-primary">Hasta (Patient)</span>
                                }
                                else if (user.RoleId == 3)
                                {

                                    <span class="badge bg-success">Doktor (Doctor)</span>
                                }
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success"><i class="bi bi-check-circle-fill"></i> Aktif</span>
                                }
                                else
                                {

                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger"><i class="bi bi-x-circle-fill"></i> Pasif</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1">Düzenle</a>
                                <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="return confirm('DİKKAT: Bu kullanıcıyı tamamen silmek istediğinize emin misiniz? (Tüm hasta/doktor izleri yok olur!)');">Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>