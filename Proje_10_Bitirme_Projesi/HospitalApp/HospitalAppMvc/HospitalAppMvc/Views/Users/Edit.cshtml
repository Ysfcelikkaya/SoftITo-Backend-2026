@model HospitalAppMvc.Models.UserViewModel

<div class="container mt-5">
    <div class="card border-0 shadow-lg rounded-4 mx-auto" style="max-width: 500px;">
        <div class="card-header bg-primary text-white p-4">
            <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> Kullanıcıyı Düzenle</h4>
        </div>
        <div class="card-body p-4 bg-white">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="PasswordHash" /> <!-- Şifreyi bozmamak için gizli gönderiyoruz -->

                <div class="mb-3">
                    <label class="form-label fw-bold">Kullanıcı Adı</label>
                    <input asp-for="Username" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">E-Posta Adresi</label>
                    <input asp-for="Email" type="email" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Kullanıcı Rolü (Yetkisi)</label>
                    <select asp-for="RoleId" class="form-select" required>
                        <option value="1">Yönetici (Admin)</option>
                        <option value="2">Hasta (Patient)</option>
                        <option value="3">Doktor (Doctor)</option>
                    </select>
                </div>
                <div class="mb-4 form-check form-switch">
                    <input class="form-check-input" type="checkbox" asp-for="IsActive" id="activeCheck">
                    <label class="form-check-label fw-bold" for="activeCheck">Hesap Aktif (Giriş Yapabilir)</label>
                </div>

                <div class="text-end">
                    <a asp-action="Index" class="btn btn-light me-2">İptal</a>
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Değişiklikleri Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>