@model HospitalAppMvc.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sisteme Giriş - HospitalApp</title>
    <!-- Modern Yazı Tipi ve Bootstrap -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                font-family: 'Outfit', sans-serif;
                margin: 0;
                padding: 0;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%, #15B8C5 100%);
                background-size: 200% 200%;
                animation: gradientAnim 10s ease infinite;
            }

            @@keyframes gradientAnim {
                0% {
                    background-position: 0% 50%;
                }

                50% {
                    background-position: 100% 50%;
                }

                100% {
                    background-position: 0% 50%;
                }
            }

            .glass-card {
                background: rgba(255, 255, 255, 0.1);
                backdrop-filter: blur(15px);
                -webkit-backdrop-filter: blur(15px);
                border-radius: 20px;
                border: 1px solid rgba(255, 255, 255, 0.2);
                padding: 40px;
                width: 100%;
                max-width: 480px;
                box-shadow: 0 25px 45px rgba(0, 0, 0, 0.2);
                color: white;
                transition: transform 0.3s ease;
            }

            /* --- ROL SEÇİM TABLARI İÇİN CSS --- */
            .role-tabs {
                display: flex;
                background: rgba(0, 0, 0, 0.2);
                border-radius: 12px;
                padding: 5px;
                margin-bottom: 25px;
            }

            .role-tab {
                flex: 1;
                text-align: center;
                padding: 10px;
                border-radius: 8px;
                cursor: pointer;
                font-size: 14px;
                font-weight: 600;
                transition: all 0.3s;
                color: rgba(255, 255, 255, 0.6);
            }

                .role-tab:hover {
                    color: white;
                }

                .role-tab.active {
                    background: linear-gradient(90deg, #15B8C5, #0E8D98);
                    color: white;
                    box-shadow: 0 4px 10px rgba(21, 184, 197, 0.4);
                }

            .glass-card h2 {
                font-weight: 600;
                margin-bottom: 20px;
                text-align: center;
                letter-spacing: 1px;
                font-size: 1.5rem;
            }

            .form-control {
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.2);
                color: white;
                border-radius: 10px;
                padding: 12px 20px;
                margin-bottom: 20px;
                transition: all 0.3s;
            }

                .form-control:focus {
                    background: rgba(255, 255, 255, 0.1);
                    border-color: #15B8C5;
                    box-shadow: 0 0 15px rgba(21, 184, 197, 0.5);
                    color: white;
                }

                .form-control::placeholder {
                    color: rgba(255, 255, 255, 0.6);
                }

            .btn-login {
                background: linear-gradient(90deg, #15B8C5, #0E8D98);
                border: none;
                border-radius: 10px;
                padding: 12px;
                font-size: 16px;
                font-weight: 600;
                width: 100%;
                color: white;
                transition: all 0.3s;
                box-shadow: 0 5px 15px rgba(21, 184, 197, 0.4);
            }

                .btn-login:hover {
                    background: linear-gradient(90deg, #0E8D98, #15B8C5);
                    box-shadow: 0 8px 25px rgba(21, 184, 197, 0.6);
                    transform: translateY(-2px);
                }

            .error-message {
                color: #ff6b6b;
                font-size: 14px;
                margin-bottom: 15px;
                text-align: center;
                font-weight: 300;
            }
    </style>
</head>
<body>

    <div class="glass-card position-relative">
        
        <!-- ANA SAYFAYA DÖN BUTONU -->
        <a href="/" class="text-white text-decoration-none opacity-75 position-absolute" style="top: 15px; left: 15px; font-size: 13px; font-weight: 500; transition: all 0.3s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.75'">
            &#8592; Ana Sayfaya Dön
        </a>

        <!-- ROL SEÇİMİ (SEKMELER) -->
        <div class="role-tabs mt-4">
            <div class="role-tab active" onclick="changeRole(this, 'hasta')">Hasta</div>
            <div class="role-tab" onclick="changeRole(this, 'doktor')">Doktor</div>
            <div class="role-tab" onclick="changeRole(this, 'admin')">Yönetici</div>
        </div>

        <h2 id="loginTitle">E-Hasta Portalı</h2>

        @if (ViewBag.Error != null)
        {
            <div class="error-message">@ViewBag.Error</div>
        }

        <form asp-controller="Auth" asp-action="Login" method="post">
            <!-- GİZLİ KAPI KONTROLCÜSÜ BURAYA EKLENDİ -->
            <input type="hidden" id="RequestedRole" asp-for="RequestedRole" value="hasta" />

            <input type="text" asp-for="Username" class="form-control" placeholder="Kullanıcı Adı" required />
            <input type="password" asp-for="Password" class="form-control" placeholder="Şifre" required />

            <div class="text-end mb-3 mt-1">
                <a href="/Auth/ForgotPassword" class="text-white text-decoration-none opacity-75" style="font-size: 13px;">Şifremi mi unuttum?</a>
            </div>

            <button type="submit" class="btn-login" id="loginBtn">Sisteme Giriş Yap</button>
            <a href="/Auth/Register" class="login-link text-center d-block mt-3 text-white text-decoration-none" id="registerLink">Hesabınız yok mu? Kayıt Olun</a>
        </form>

        <div class="text-center mt-4" style="font-size: 13px; color: rgba(255,255,255,0.6);">
            &copy; 2026 Hospital Management System
        </div>
    </div>

    <!-- SEKMELER ARASI GEÇİŞ İÇİN JAVASCRIPT -->
    <script>
            function changeRole(element, role) {
                // Tüm sekmelerden aktif rengini kaldır
                document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));
                // Tıklanan sekmeyi renklendir
                element.classList.add('active');

                const title = document.getElementById('loginTitle');
                const registerLink = document.getElementById('registerLink');
                const requestedRoleInput = document.getElementById('RequestedRole');

                // JAVASCRIPT KONTROLCÜSÜ BURAYA EKLENDİ
                requestedRoleInput.value = role;

                if(role === 'hasta') {
                    title.innerText = 'E-Hasta Portalı';
                    registerLink.style.display = 'block'; // Hastalar kayıt olabilir
                } else if (role === 'doktor') {
                    title.innerText = 'Doktor Bilişim Sistemi';
                    registerLink.style.display = 'none'; // Doktorlar dışarıdan kayıt Olamaz!
                } else if (role === 'admin') {
                    title.innerText = 'Yönetim Paneli';
                    registerLink.style.display = 'none'; // Adminler dışarıdan kayıt Olamaz!
                }
            }
    </script>
</body>
</html>