@{
    Layout = null; // Menüleri gizliyoruz, tamamen temiz bir ekran
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Şifremi Unuttum - HospitalApp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
            body {
                background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
                height: 100vh;
                display: flex;
                align-items: center;
            }

            .auth-card {
                background: rgba(255, 255, 255, 0.95);
                backdrop-filter: blur(10px);
                border-radius: 20px;
                box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            }

            .icon-circle {
                width: 80px;
                height: 80px;
                background-color: #fff3cd;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto;
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="auth-card p-5">
                    <div class="text-center mb-4">
                        <div class="icon-circle mb-3 shadow-sm">
                            <i class="bi bi-shield-lock-fill text-warning" style="font-size: 2.5rem;"></i>
                        </div>
                        <h3 class="fw-bold text-dark mt-2">Şifremi Unuttum</h3>
                        <p class="text-muted" style="font-size: 14px;">Kullanıcı adınızı girerek şifrenizi güvenli bir şekilde sıfırlayabilirsiniz.</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger fw-bold border-0 shadow-sm"><i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error</div>
                    }
                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success fw-bold border-0 shadow-sm"><i class="bi bi-check-circle-fill"></i> @ViewBag.Success</div>
                        <div class="text-center mt-4">
                            <a href="/Auth/Login" class="btn btn-success fw-bold rounded-pill w-100 py-2 shadow-sm">Giriş Yapmaya Git</a>
                        </div>
                    }
                    else
                    {
                        <form action="/Auth/ForgotPassword" method="post">

                            <!-- KULLANICI ADI KUTUSU -->
                            <div class="mb-3">
                                <label class="form-label fw-bold text-muted" style="font-size: 13px;">Kullanıcı Adı</label>
                                <div class="input-group input-group-lg shadow-sm">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-person text-warning"></i></span>
                                    <input type="text" name="Username" class="form-control border-start-0 ps-0" required placeholder="Sisteme kayıtlı adınız" />
                                </div>
                            </div>

                            <!-- YENİ ŞİFRE KUTUSU (YENİ EKLENDİ) -->
                            <div class="mb-4">
                                <label class="form-label fw-bold text-muted" style="font-size: 13px;">Yeni Şifreniz</label>
                                <div class="input-group input-group-lg shadow-sm">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-key text-warning"></i></span>
                                    <input type="password" name="NewPassword" class="form-control border-start-0 ps-0" required placeholder="Kullanmak istediğiniz yeni şifre" minlength="4" />
                                </div>
                            </div>

                            <button type="submit" class="btn btn-warning w-100 fw-bold rounded-pill py-3 text-dark shadow-sm fs-5">
                                Şifremi Değiştir
                            </button>
                            <div class="text-center mt-4">
                                <a href="/Auth/Login" class="text-decoration-none text-muted fw-bold"><i class="bi bi-arrow-left"></i> Giriş Ekranına Dön</a>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</body>
</html>