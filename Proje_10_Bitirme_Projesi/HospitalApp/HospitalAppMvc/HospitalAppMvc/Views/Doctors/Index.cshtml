@model IEnumerable<HospitalAppMvc.Models.DoctorViewModel>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: #2a5298;">👨‍⚕️ Doktorlarımız</h2>

        <!-- İŞTE BURASI DÜZELDİ: Artık Create sayfasına gidiyor -->
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm">
                + Yeni Doktor Ekle
            </a>
        }
    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="text-white" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);">
                    <tr>
                        <th class="py-3 px-4">Ünvan / İsim</th>
                        <th class="py-3 px-4 text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var doc in Model)
                        {
                            <tr>
                                <td class="py-3 px-4 fw-bold text-dark">
                                    <span class="badge bg-light text-primary me-2">@(doc.Title ?? "Uzm. Dr.")</span>
                                    @doc.FirstName @doc.LastName
                                </td>
                                <td class="py-3 px-4 text-end">

                                    <!-- SADECE ADMİN DÜZENLE VE SİL BUTONUNU GÖREBİLİR -->
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <!-- YENİ EKLENEN DÜZENLE BUTONU -->
                                        <a asp-action="Edit" asp-route-id="@doc.Id" class="btn btn-sm btn-warning fw-bold rounded-pill px-3 shadow-sm me-2 text-dark">
                                            ✏️ Düzenle
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@doc.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-danger fw-bold rounded-pill px-3 shadow-sm" onclick="return confirm('Bu doktoru silmek istediğinize emin misiniz?');">
                                                🗑️ Sil
                                            </button>
                                        </form>
                                    }

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center py-5 text-muted">Sistemde henüz doktor bulunmamaktadır.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>