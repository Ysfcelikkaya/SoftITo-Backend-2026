@model HospitalAppMvc.Models.MedicalRecordViewModel
@{
    Layout = null; // Yan menü (Sidebar) falan görünmemesi için iptal ediyoruz
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Muayene Raporu - @Model.PatientName</title>
    <!-- Modern Fonts and Bootstrap -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
            color: #333;
        }

        .a4-container {
            width: 210mm;
            min-height: 297mm;
            padding: 20mm;
            margin: 20mm auto;
            background: white;
            box-shadow: 0 0 15px rgba(0,0,0,0.1);
            position: relative;
        }

        .hospital-header {
            border-bottom: 3px solid #1e3c72;
            padding-bottom: 15px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .hospital-logo h2 {
            color: #1e3c72;
            font-weight: 700;
            margin: 0;
            letter-spacing: 1px;
        }

        .report-title {
            text-align: center;
            font-weight: 700;
            font-size: 24px;
            color: #2c3e50;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .info-box {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            border: 1px solid #e9ecef;
        }

        .info-label {
            font-size: 12px;
            color: #6c757d;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .info-value {
            font-size: 16px;
            font-weight: 600;
            color: #2b2d42;
        }

        .section-title {
            font-size: 18px;
            font-weight: 700;
            color: #1e3c72;
            border-bottom: 2px solid #e9ecef;
            padding-bottom: 8px;
            margin-top: 30px;
            margin-bottom: 15px;
        }

        .content-box {
            background: #ffffff;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 20px;
            min-height: 80px;
            font-size: 14px;
            line-height: 1.6;
        }

        .footer {
            margin-top: 50px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            padding-top: 20px;
            border-top: 1px solid #dee2e6;
        }

        .signature-box {
            text-align: center;
            width: 200px;
        }

        .signature-line {
            border-bottom: 1px solid #333;
            margin-bottom: 10px;
            height: 40px;
        }

        /* YAZDIRMA (CTRL+P) ESNASINDA DEVREYE GİREN CSS */
        @@media print {
            body {
                background: white;
            }
            .a4-container {
                margin: 0;
                padding: 0;
                box-shadow: none;
                width: 100%;
                min-height: auto;
            }
            .no-print {
                display: none !important; /* Butonu yazıcıda gizler */
            }
        }
    </style>
</head>
<body>

    <!-- SADECE EKRANDA GÖRÜNEN BUTONLAR (ÇIKTIDA GİZLENİR) -->
    <div class="text-center my-4 no-print">
        <button onclick="window.print()" class="btn btn-primary px-5 py-2 fw-bold rounded-pill shadow">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-printer me-2" viewBox="0 0 16 16">
                <path d="M2.5 8a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1z" />
                <path d="M5 1a2 2 0 0 0-2 2v2H2a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h1v1a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1V3a2 2 0 0 0-2-2H5zM4 3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2H4V3zm1 5a2 2 0 0 0-2 2v1H2a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v-1a2 2 0 0 0-2-2H5zm7 2v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1z" />
            </svg>
            PDF Olarak İndir / Yazdır
        </button>
        <a href="javascript:history.back()" class="btn btn-light border px-4 py-2 ms-2 rounded-pill fw-bold text-muted">Geri Dön</a>
    </div>

    <!-- A4 RAPOR ALANI -->
    <div class="a4-container">
        
        <div class="hospital-header">
            <div class="hospital-logo">
                <h2>HOSPITAL APP</h2>
                <small class="text-muted" style="font-weight: 500;">Modern Sağlık Bilgi Sistemi</small>
            </div>
            <div class="text-end" style="font-size: 12px; color: #666;">
                <div><strong>Rapor Tarihi:</strong> @Model.ReportDate.ToString("dd.MM.yyyy HH:mm")</div>
                <div><strong>Rapor No:</strong> #MR-@Model.Id.ToString("D5")</div>
            </div>
        </div>

        <div class="report-title">
            TIBBİ MUAYENE RAPORU
        </div>

        <div class="info-grid">
            <div class="info-box">
                <div class="info-label">Hasta Bilgileri</div>
                <div class="info-value">@Model.PatientName</div>
            </div>
            <div class="info-box">
                <div class="info-label">Sorumlu Hekim</div>
                <div class="info-value">@Model.DoctorName</div>
                <div style="font-size: 12px; color: #666; margin-top: 3px;">Muayene Tarihi: @Model.RecordDate.ToString("dd.MM.yyyy")</div>
            </div>
        </div>

        <div class="section-title">Klinik Tanı (Teşhis)</div>
        <div class="content-box" style="font-weight: 600; color: #dc3545; font-size: 16px;">
            @Model.Diagnosis
        </div>

        @if (!string.IsNullOrEmpty(Model.LabAndXRayResults))
        {
            <div class="section-title">Laboratuvar ve Görüntüleme (Röntgen) Sonuçları</div>
            <div class="content-box">
                @Model.LabAndXRayResults
            </div>
        }

        <div class="section-title">Reçete ve İlaç Tedavisi</div>
        <div class="content-box">
            <div style="font-weight: 600; margin-bottom: 5px; color: #0284c7;">Reçete Özeti: @Model.Prescription</div>
            @if (!string.IsNullOrEmpty(Model.Medicines))
            {
                <div style="margin-top: 10px; border-top: 1px dashed #ccc; padding-top: 10px;">
                    <strong>Detaylı İlaç Kullanımı:</strong><br />
                    @Model.Medicines
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="section-title">Hekim Tavsiyeleri ve Notlar</div>
            <div class="content-box" style="font-style: italic; background-color: #fdfbf7;">
                @Model.Notes
            </div>
        }

        <div class="footer">
            <div style="font-size: 12px; color: #6c757d; max-width: 60%;">
                <strong>Yasal Uyarı:</strong> Bu rapor elektronik ortamda üretilmiş olup, barkod ve e-imza gerektirmeden geçerlidir. Resmi evrak niteliği taşımaz, sadece hastayı bilgilendirme amaçlıdır.
            </div>
            <div class="signature-box">
                <div class="signature-line"></div>
                <div style="font-weight: 600; font-size: 14px;">@Model.DoctorName</div>
                <div style="font-size: 12px; color: #666;">İmza / Kaşe</div>
            </div>
        </div>

    </div>

</body>
</html>