<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HospitalApp</title>
    <!-- Modern Yazı Tipleri ve İkonlar -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap İkonları -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
            body {
                font-family: 'Inter', sans-serif;
                background-color: #f4f7f6;
                overflow-x: hidden;
            }

            /* ================= SIDEBAR (YAN MENÜ) TASARIMI ================= */
            #sidebar {
                width: 280px;
                position: fixed;
                top: 0;
                left: 0;
                height: 100vh;
                background: linear-gradient(180deg, #111827 0%, #1f2937 100%);
                color: white;
                transition: all 0.3s;
                z-index: 1000;
                box-shadow: 4px 0 15px rgba(0,0,0,0.1);
                overflow-y: auto; /* Küçük ekranlarda aşağıya kaydırmayı sağlar */
            }

            .sidebar-header {
                padding: 25px 20px;
                background: rgba(0,0,0,0.2);
                border-bottom: 1px solid rgba(255,255,255,0.05);
            }

                .sidebar-header h4 {
                    font-weight: 700;
                    letter-spacing: 1px;
                    margin: 0;
                    color: #fff;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                }

            .sidebar-nav {
                padding: 20px 0;
                list-style: none;
                margin: 0;
            }

                .sidebar-nav li {
                    padding: 5px 20px;
                    margin-bottom: 5px;
                }

                .sidebar-nav a {
                    color: rgba(255,255,255,0.7);
                    text-decoration: none;
                    display: flex;
                    align-items: center;
                    padding: 12px 15px;
                    border-radius: 8px;
                    font-weight: 500;
                    transition: all 0.3s ease;
                }

                    .sidebar-nav a:hover, .sidebar-nav a.active {
                        color: #fff;
                        background: rgba(255,255,255,0.1);
                        transform: translateX(5px);
                    }

                .sidebar-nav i {
                    margin-right: 15px;
                    font-size: 1.2rem;
                    width: 20px;
                    text-align: center;
                }

            /* ================= ANA İÇERİK (SAĞ TARAF) ================= */
            #page-content-wrapper {
                margin-left: 280px;
                width: calc(100% - 280px);
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                transition: all 0.3s;
            }

            /* ÜST BAR (Navbarın yerine gelen ince şık profil alanı) */
            .top-navbar {
                background: #fff;
                padding: 15px 30px;
                box-shadow: 0 2px 15px rgba(0,0,0,0.03);
                display: flex;
                justify-content: flex-end;
                align-items: center;
            }

            .user-profile {
                display: flex;
                align-items: center;
                gap: 15px;
            }

            .btn-logout {
                background: #fee2e2;
                color: #ef4444;
                border-radius: 8px;
                font-weight: 600;
                padding: 6px 15px;
                text-decoration: none;
                transition: all 0.3s;
            }

                .btn-logout:hover {
                    background: #ef4444;
                    color: white;
                }

            .main-content {
                padding: 30px;
                flex-grow: 1;
            }

            /* ================= CHATBOT ================= */
            #ai-chat-widget {
                position: fixed;
                bottom: 30px;
                right: 30px;
                z-index: 9999;
            }

            #ai-chat-btn {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                color: white;
                border-radius: 50%;
                width: 60px;
                height: 60px;
                display: flex;
                align-items: center;
                justify-content: center;
                border: none;
                transition: transform 0.3s;
            }

                #ai-chat-btn:hover {
                    transform: scale(1.1);
                }

            #ai-chat-window {
                width: 350px;
                background: white;
                border: 1px solid #e0e0e0;
                position: absolute;
                bottom: 75px;
                right: 0;
                transition: all 0.3s ease;
            }

            .chat-header {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            }

            .message-bubble {
                font-size: 14px;
                display: inline-block;
                max-width: 85%;
            }

            .user-message {
                text-align: right;
            }

                .user-message .message-bubble {
                    background: #3A8DFF;
                    color: white;
                    border: none;
                    border-bottom-right-radius: 0 !important;
                }

            .bot-message .message-bubble {
                border-bottom-left-radius: 0 !important;
            }

            .recommended-badge {
                font-size: 12px;
                font-weight: 600;
                padding: 5px 10px;
                margin-top: 5px;
                display: inline-block;
                background: #E67E22;
                color: white;
                border-radius: 10px;
            }
    </style>
</head>
<body>

    <div class="d-flex">

        <!-- YAN MENÜ (SIDEBAR) -->
        <nav id="sidebar">
            <div class="sidebar-header">
                <h4><i class="bi bi-hospital" style="font-size:28px;"></i> HospitalApp</h4>
            </div>

            <ul class="sidebar-nav">
                <li>
                    <a asp-controller="Home" asp-action="Index"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
                </li>

                @if (User.Identity.IsAuthenticated)
                {
                    <li><a asp-controller="Appointments" asp-action="Index"><i class="bi bi-calendar-check-fill"></i> Randevularım</a></li>

                    <!-- YENİ EKLENEN HASTA KISAYOLU BURADA! -->
                    <li><a asp-controller="MedicalRecords" asp-action="Index"><i class="bi bi-file-earmark-medical-fill text-danger"></i> Muayene Raporlarım</a></li>
                    <!-- HASTALAR İÇİN FATURA LİNKİ -->
                    <li><a asp-controller="Invoices" asp-action="Index"><i class="bi bi-credit-card-2-front-fill text-success"></i> Faturalarım</a></li>

                    @if (User.IsInRole("Admin") || User.IsInRole("Doktor") || User.IsInRole("Doctor"))
                    {
                        <li><a asp-controller="Patients" asp-action="Index"><i class="bi bi-people-fill"></i> Hasta Listesi</a></li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="mt-4 mb-2 px-3 text-uppercase text-muted" style="font-size: 11px; font-weight: 700; letter-spacing: 1px;">Yönetim Paneli</li>

                        <li><a asp-controller="Users" asp-action="Index"><i class="bi bi-person-lines-fill text-secondary"></i> Kullanıcı Yönetimi</a></li>
                        <li><a asp-controller="Doctors" asp-action="Index"><i class="bi bi-heart-pulse-fill text-danger"></i> Doktor Yönetimi</a></li>
                        <li><a asp-controller="Departments" asp-action="Index"><i class="bi bi-building-fill text-info"></i> Poliklinikler</a></li>
                        <li><a asp-controller="Rooms" asp-action="Index"><i class="bi bi-door-open-fill text-warning"></i> Odalar (Rooms)</a></li>
                        <li><a asp-controller="Admissions" asp-action="Index"><i class="bi bi-hospital-fill text-primary"></i> Hasta Yatışları</a></li>
                        <li><a asp-controller="Invoices" asp-action="Index"><i class="bi bi-receipt-cutoff text-success"></i> Faturalar</a></li>
                    }
                }
            </ul>
        </nav>

        <!-- SAĞ TARAF (İÇERİK) -->
        <div id="page-content-wrapper">

            <!-- ÜST BAR (Profil) -->
            <div class="top-navbar">
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="user-profile">
                        <div class="text-end">
                            <div class="fw-bold text-dark" style="font-size: 14px;">@User.Identity.Name</div>
                            <div class="text-muted" style="font-size: 12px; font-weight: 600;">
                                @{
                                    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
                                    var displayRole = userRole == "Patient" ? "Hasta" :
                                                      userRole == "Doctor" ? "Doktor" :
                                                      userRole == "Admin" ? "Yönetici" : userRole;
                                }
                                <i class="bi bi-shield-check me-1"></i>@displayRole
                            </div>
                        </div>
                        <div class="bg-dark text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 40px; height: 40px;">
                            @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                        </div>
                        <a asp-controller="Auth" asp-action="Logout" class="btn-logout ms-2"><i class="bi bi-box-arrow-right"></i> Çıkış Yap</a>
                    </div>
                }
            </div>

            <!-- SAYFALARIN AÇILACAĞI ALAN -->
            <div class="main-content">
                @RenderBody()
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- AI CHATBOT -->
    <div id="ai-chat-widget">
        <button id="ai-chat-btn" class="btn shadow-lg" onclick="toggleChat()"><span style="font-size: 24px;">🤖</span></button>
        <div id="ai-chat-window" class="shadow-lg rounded-3 d-none">
            <div class="chat-header text-white p-3 rounded-top d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold">🤖 Semptom Kontrol Botu</h6>
                <button type="button" class="btn-close btn-close-white" onclick="toggleChat()"></button>
            </div>
            <div id="chat-messages" class="p-3" style="height: 300px; overflow-y: auto; background-color: #f8f9fa;">
                <div class="chat-message bot-message mb-3">
                    <div class="message-bubble bg-white p-2 rounded shadow-sm border">Merhaba! Şikayetiniz nedir?</div>
                </div>
            </div>
            <div class="chat-input p-2 border-top bg-white rounded-bottom d-flex">
                <input type="text" id="chat-input-text" class="form-control form-control-sm me-2" placeholder="Şikayet..." onkeypress="handleKeyPress(event)" />
                <button class="btn btn-sm btn-primary px-3" onclick="sendMessage()">Gönder</button>
            </div>
        </div>
    </div>
    <script>
        function toggleChat() { document.getElementById('ai-chat-window').classList.toggle('d-none'); }
        function handleKeyPress(e) { if (e.key === 'Enter') sendMessage(); }
        async function sendMessage() {
        var input = document.getElementById('chat-input-text');
        var text = input.value.trim();
        if (!text) return;
        var chatMessages = document.getElementById('chat-messages');
        chatMessages.innerHTML += `<div class="chat-message user-message mb-3"><div class="message-bubble p-2 rounded shadow-sm">${text}</div></div>`;
        input.value = '';
        chatMessages.scrollTop = chatMessages.scrollHeight;
        try {
        // ============= DİKKAT: PORTUNUZU BURAYA YAZIN (Örn: 7150) =============
        var response = await fetch('https://localhost:7150/api/AIChat/Analyze', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text })
        });
        if (response.ok) {
        var data = await response.json();
        var badgeHtml = data.recommendedDepartment ? `<div class="recommended-badge mt-2">🏥 Yönlendirme: ${data.recommendedDepartment}</div>` : '';
        chatMessages.innerHTML += `<div class="chat-message bot-message mb-3"><div class="message-bubble bg-white p-2 rounded shadow-sm border">${data.reply}${badgeHtml}</div></div>`;
        } else { chatMessages.innerHTML += `<div class="text-danger text-center small my-2">API Hatası!</div>`; }
        } catch (error) { chatMessages.innerHTML += `<div class="text-danger text-center small my-2">Bağlantı koptu.</div>`; }
        chatMessages.scrollTop = chatMessages.scrollHeight;
        }
    </script>
</body>
</html>