@model HospitalAppMvc.Models.InvoiceViewModel

<div class="container mt-5">
    <div class="card border-0 shadow-lg rounded-4 mx-auto" style="max-width: 550px;">
        <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #10b981 0%, #047857 100%);">
            <h4 class="mb-0 fw-bold"><i class="bi bi-receipt-cutoff me-2"></i> Yeni Fatura Kes</h4>
            <p class="mb-0 mt-1 opacity-75" style="font-size: 13px;">Ayakta (Randevu) veya Yatarak (Oda) tedaviye fatura kesebilirsiniz.</p>
        </div>
        <div class="card-body p-4 bg-white">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger fw-bold">@TempData["Error"]</div>
            }

            <form asp-action="Create" method="post">

                <div class="alert alert-warning p-2 text-center fw-bold" style="font-size:13px;">
                    DİKKAT: Aşağıdaki kutulardan sadece birini seçmeniz yeterlidir!
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-primary">Ayakta Tedavi (Randevu) Seçimi</label>
                    <select asp-for="AppointmentId" class="form-select border-2 border-primary">
                        <option value="">-- Randevu Yok --</option>
                        @if (ViewBag.Appointments != null)
                        {
                            foreach (var app in (IEnumerable<SelectListItem>)ViewBag.Appointments)
                            {
                                <option value="@app.Value">@app.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-danger">Yatarak Tedavi (Oda Yatışı) Seçimi</label>
                    <select asp-for="AdmissionId" class="form-select border-2 border-danger">
                        <option value="">-- Yatış Yok --</option>
                        @if (ViewBag.Admissions != null)
                        {
                            foreach (var adm in (IEnumerable<SelectListItem>)ViewBag.Admissions)
                            {
                                <option value="@adm.Value">@adm.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-5">
                    <label class="form-label fw-bold text-muted">Fatura Tutarı (₺)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-2 text-success fw-bold">₺</span>
                        <input asp-for="Amount" type="number" step="0.01" class="form-control border-2 form-control-lg fw-bold text-dark" placeholder="Örn: 1500.50" required />
                    </div>
                </div>

                <div class="text-end border-top pt-3">
                    <a asp-action="Index" class="btn btn-light border fw-bold me-2 px-4">İptal</a>
                    <button type="submit" class="btn btn-success fw-bold px-4"><i class="bi bi-send-check"></i> Faturayı Oluştur</button>
                </div>
            </form>
        </div>
    </div>
</div>