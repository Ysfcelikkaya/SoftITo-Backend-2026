@model IEnumerable<HospitalAppMvc.Models.AppointmentViewModel>

<div class="container mt-5">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger fw-bold shadow-sm rounded-3">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm rounded-3">@TempData["SuccessMessage"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-calendar2-check-fill text-primary"></i> Randevularım</h2>
        <a asp-controller="Appointments" asp-action="Create" class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm">
            + Yeni Randevu Al
        </a>
    </div>

    <!-- 1. AKTİF (BEKLEYEN) RANDEVULAR -->
    <h4 class="fw-bold text-primary mb-3">⏳ Aktif Randevular</h4>
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-5">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle text-center">
                <thead class="text-white" style="background: linear-gradient(180deg, #111827 0%, #1f2937 100%);">
                    <tr>
                        <th class="py-3 px-4">Tarih</th>
                        <th class="py-3 px-4">Hasta Adı</th>
                        <th class="py-3 px-4">Doktor Adı</th>
                        <th class="py-3 px-4">Durum</th>
                        <th class="py-3 px-4 text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @if (Model != null && Model.Any(a => a.Status == "Pending"))
                    {
                        foreach (var app in Model.Where(a => a.Status == "Pending"))
                        {
                            <tr>
                                <td class="py-3 px-4 fw-bold">@app.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="py-3 px-4 text-primary fw-bold">@app.PatientName</td>
                                <td class="py-3 px-4 text-danger fw-bold">@app.DoctorName</td>
                                <td class="py-3 px-4">
                                    <span class="badge bg-warning text-dark rounded-pill px-3 py-2">Bekliyor</span>
                                </td>
                                <td class="py-3 px-4 text-end">
                                    @if (User.IsInRole("Admin") || User.IsInRole("Doktor") || User.IsInRole("Doctor"))
                                    {
                                        <form action="/Appointments/UpdateStatus" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@app.Id" />
                                            <input type="hidden" name="newStatus" value="Completed" />
                                            <button type="submit" class="btn btn-sm btn-success fw-bold rounded-pill px-3 shadow-sm me-1">✅ Tamamla</button>
                                        </form>
                                    }

                                    <form action="/Appointments/UpdateStatus" method="post" class="d-inline" onsubmit="return confirm('Randevuyu iptal etmek istediğinize emin misiniz?');">
                                        <input type="hidden" name="id" value="@app.Id" />
                                        <input type="hidden" name="newStatus" value="Cancelled" />
                                        <button type="submit" class="btn btn-sm btn-danger fw-bold rounded-pill px-3 shadow-sm">❌ İptal Et</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted fw-bold">⏳ Şimdilik aktif bir randevunuz bulunmuyor.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- 2. GEÇMİŞ RANDEVULAR -->
    <h4 class="fw-bold text-secondary mb-3">🕰️ Geçmiş Randevular</h4>
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="opacity: 0.85;">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle text-center bg-light">
                <thead class="text-secondary bg-light">
                    <tr>
                        <th class="py-3 px-4">Tarih</th>
                        <th class="py-3 px-4">Hasta Adı</th>
                        <th class="py-3 px-4">Doktor Adı</th>
                        <th class="py-3 px-4">Sonuç</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any(a => a.Status == "Completed" || a.Status == "Cancelled"))
                    {
                        foreach (var app in Model.Where(a => a.Status == "Completed" || a.Status == "Cancelled"))
                        {
                            <tr>
                                <td class="py-3 px-4 text-muted">@app.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="py-3 px-4 text-muted">@app.PatientName</td>
                                <td class="py-3 px-4 text-muted">@app.DoctorName</td>
                                <td class="py-3 px-4">
                                    @if (app.Status == "Completed")
                                    {
                                        <span class="badge bg-success bg-opacity-75 rounded-pill px-3 py-2">Tamamlandı</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-75 rounded-pill px-3 py-2">İptal Edildi</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center py-4 text-muted">Geçmiş randevu kaydı bulunmuyor.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>