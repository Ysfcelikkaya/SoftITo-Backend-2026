@model IEnumerable<DbFirstProject.Models.Hasta>
<h2>Hasta Sayfası</h2>
<p>
	<a asp-action="Create" class="btn btn-primary">Yeni Hasta</a>

</p>
<table class="table">



	<thead>
		<tr>
			<th>@Html.DisplayNameFor(model => model.TcNo)</th>
			<th>@Html.DisplayNameFor(model => model.Ad)</th>
			<th>@Html.DisplayNameFor(model => model.Soyad)</th>
			<th>@Html.DisplayNameFor(model => model.DogumTarihi)</th>
			<th>@Html.DisplayNameFor(model => model.Cinsiyet)</th>
			<th></th>
		</tr>
	</thead>

	<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td>@Html.DisplayFor(modelItem => item.TcNo)</td>
				<td>@Html.DisplayFor(modelItem => item.Ad)</td>
				<td>@Html.DisplayFor(modelItem => item.Soyad)</td>
				<td>@Html.DisplayFor(modelItem => item.DogumTarihi)</td>
				<td>@Html.DisplayFor(modelItem => item.Cinsiyet)</td>
				<td>
					<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success">Edit</a>
					<a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
				</td>

			</tr>


		}
	</tbody>







</table>
