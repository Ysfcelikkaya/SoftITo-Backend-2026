@model DbFirstProject.Models.Randevu
@{
    ViewData["Title"] = "Randevu Düzenle";
}

<div class="container-fluid mt-4">
    <div class="card shadow mb-4" style="max-width: 600px; margin: 0 auto;">
        <div class="card-header py-3 bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="m-0 font-weight-bold"><i class="bi bi-pencil-square"></i> Randevu Bilgilerini Düzenle</h5>
            <a asp-action="Index" class="btn btn-sm btn-light">Listeye Dön</a>
        </div>
        <div class="card-body">

            <form asp-action="Edit" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="HastaId" class="form-label fw-bold text-dark">Hasta Seçimi</label>
                    <select asp-for="HastaId" class="form-select fw-semibold" asp-items="ViewBag.HastaId">
                        <option value="">-- Hasta Seçiniz --</option>
                    </select>
                    <span asp-validation-for="HastaId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DoktorId" class="form-label fw-bold text-dark">Doktor Seçimi</label>
                    <select asp-for="DoktorId" class="form-select fw-semibold" asp-items="ViewBag.DoktorId">
                        <option value="">-- Doktor Seçiniz --</option>
                    </select>
                    <span asp-validation-for="DoktorId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="RandevuTarihi" class="form-label fw-bold text-dark">Randevu Tarihi ve Saati</label>
                    <input asp-for="RandevuTarihi" type="datetime-local" class="form-control" />
                    <span asp-validation-for="RandevuTarihi" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Sikayet" class="form-label fw-bold text-dark">Hastanın Şikayeti</label>
                    <textarea asp-for="Sikayet" class="form-control" rows="3" placeholder="Şikayet detaylarını yazın..."></textarea>
                    <span asp-validation-for="Sikayet" class="text-danger small"></span>
                </div>

                <hr />

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary px-4">İptal Et</a>
                    <button type="submit" class="btn btn-success px-4fw-bold">
                        <i class="bi bi-check-circle-fill"></i> Değişiklikleri Kaydet
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}