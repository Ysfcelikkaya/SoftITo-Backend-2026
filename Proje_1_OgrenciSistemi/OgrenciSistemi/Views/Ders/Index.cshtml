@model IEnumerable<OgrenciSistemi.Models.Ders>
<p>
	<a asp-action="Create" class="btn btn-primary">Create New</a>

</p>
<table class="table">



	<thead>
		<tr>
			<th>@Html.DisplayNameFor(model => model.DersAdi)</th>
			<th>@Html.DisplayNameFor(model => model.DersKredi)</th>
			<th></th>
		</tr>
	</thead>

	<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td>@Html.DisplayFor(modelItem => item.DersAdi)</td>
				<td>@Html.DisplayFor(modelItem => item.DersKredi)</td>
				<td>
					<a asp-action="Edit" asp-route-id="@item.DersNo" class="btn btn-success">Edit</a>
					<a asp-action="Delete" asp-route-id="@item.DersNo" class="btn btn-danger">Delete</a>
				</td>

			</tr>


		}
	</tbody>







</table>
