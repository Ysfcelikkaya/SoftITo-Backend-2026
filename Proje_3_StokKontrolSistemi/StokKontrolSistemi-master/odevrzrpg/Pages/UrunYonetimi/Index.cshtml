@page
@model odevrzrpg.Pages.UrunYonetimi.IndexModel
@{
    ViewData["Title"] = "Ürün Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Mini Stok & Ürün Yönetimi</h2>
        <a class="btn btn-primary" href="/UrunYonetimi/Create">Yeni Ürün Ekle</a>
    </div>

    <table class="table table-striped table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Ürün Adı</th>
                <th>Kategori</th>
                <th>Fiyat (TL)</th>
                <th>Stok Adeti</th>
                <th>Kayıt Tarihi</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.listele.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">Henüz hiç ürün eklenmemiş.</td>
                </tr>
            }
            else
            {
                foreach (var urun in Model.listele)
                {
                    <tr>
                        <td>@urun.Id</td>
                        <td>@urun.UrunAdi</td>
                        <td>@urun.Kategori</td>
                        <td>@urun.Fiyat</td>
                        <td>@urun.StokAdeti</td>
                        <td>@urun.KayitTarihi</td>
                        <td>
                            <a class="btn btn-warning btn-sm" href="/UrunYonetimi/Edit?id=@urun.Id">Düzenle</a>
                            <a class="btn btn-danger btn-sm" href="/UrunYonetimi/Delete?id=@urun.Id">Sil</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>