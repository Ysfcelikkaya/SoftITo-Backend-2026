@page
@model odevrzrpg.Pages.Satislar.IndexModel
@{
    ViewData["Title"] = "Satış Geçmişi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Satış & Kasa Defteri</h2>
        <a class="btn btn-warning" href="/Satislar/Create">Yeni Satış Yap (Stoktan Düş)</a>
    </div>

    <table class="table table-striped table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>İşlem No</th>
                <th>Müşteri Ad Soyad</th>
                <th>Satılan Ürün</th>
                <th>Adet</th>
                <th>Toplam Tutar (TL)</th>
                <th>Satış Tarihi</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.listele.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">Henüz hiç satış yapılmamış.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model.listele)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.MusteriAdSoyad</td>
                        <td>@item.UrunAdi</td>
                        <td>@item.Adet</td>
                        <td>@item.ToplamTutar</td>
                        <td>@item.SatisTarihi</td>
                        <td>
                            <a class="btn btn-danger btn-sm" href="/Satislar/Delete?id=@item.Id">Satışı İptal Et</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>