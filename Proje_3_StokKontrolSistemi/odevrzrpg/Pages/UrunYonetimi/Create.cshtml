@page
@model odevrzrpg.Pages.UrunYonetimi.CreateModel
@{
    ViewData["Title"] = "Yeni Ürün Ekle";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2>Yeni Ürün Ekle</h2>

    @if (Model.errorMessage.Length > 0)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Hata:</strong> @Model.errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.successMessage.Length > 0)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Başarılı!</strong> @Model.successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="POST">
        <div class="mb-3">
            <label class="form-label">Ürün Adı</label>
            <input type="text" class="form-control" name="UrunAdi" value="@Model.urunbilgi.UrunAdi">
        </div>

        <div class="mb-3">
            <label class="form-label">Kategori</label>
            <input type="text" class="form-control" name="Kategori" value="@Model.urunbilgi.Kategori">
        </div>

        <div class="mb-3">
            <label class="form-label">Fiyat (TL)</label>
            <input type="number" step="0.01" class="form-control" name="Fiyat" value="@Model.urunbilgi.Fiyat">
        </div>

        <div class="mb-3">
            <label class="form-label">Stok Adeti</label>
            <input type="number" class="form-control" name="StokAdeti" value="@Model.urunbilgi.StokAdeti">
        </div>

        <div class="mb-3">
            <label class="form-label">Kayıt Tarihi</label>
            <input type="datetime-local" class="form-control" name="KayitTarihi" value="@Model.urunbilgi.KayitTarihi">
        </div>

        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a class="btn btn-outline-secondary" href="/UrunYonetimi/Index">İptal</a>
    </form>
</div>