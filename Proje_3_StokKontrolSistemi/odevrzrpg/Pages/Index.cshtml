@page
@model odevrzrpg.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid px-4 mt-4">
    <h2 class="mb-4"><i class="fas fa-chart-line me-2"></i> Stok Kontrol Dashboard</h2>

    <!-- DİNAMİK İSTATİSTİK KARTLARI -->
    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card bg-primary text-white shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">Depodaki Toplam Ürün</h5>
                    <h2 class="fw-bold">@Model.ToplamUrunAdedi Adet</h2>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card bg-warning text-white shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">Kritik Stok (10 altı)</h5>
                    <h2 class="fw-bold">@Model.KritikStokSayisi Adet</h2>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card bg-success text-white shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">Çeşit (Farklı Ürün)</h5>
                    <h2 class="fw-bold">@Model.UrunListesi.Count Çeşit</h2>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card bg-danger text-white shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">Kayıtlı Personel</h5>
                    <h2 class="fw-bold">@Model.TotalUsers Kişi</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- DİNAMİK ÜRÜN TABLOSU -->
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary"><i class="fas fa-table me-1"></i> Güncel Stok Listesi</h6>
            <!-- Ürün Ekle Butonu (Modal'ı açar) -->
            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#urunEkleModal">
                <i class="fas fa-plus"></i> Yeni Ürün Ekle
            </button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle" width="100%" cellspacing="0">
                    <thead class="table-light">
                        <tr>
                            <th>Ürün Kodu</th>
                            <th>Ürün Adı</th>
                            <th>Kategori</th>
                            <th>Miktar</th>
                            <th>Durum</th>
                            <th class="text-center">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.UrunListesi.Count == 0)
                        {
                            <tr><td colspan="6" class="text-center text-muted">Henüz ürün eklenmemiş.</td></tr>
                        }

                        <!-- C# Tarafındaki Listeyi Döngüye Alıyoruz -->
                        @foreach (var urun in Model.UrunListesi)
                        {
                            <tr>
                                <td><span class="fw-bold text-secondary">@urun.Kodu</span></td>
                                <td>@urun.Adi</td>
                                <td>@urun.Kategori</td>
                                <td>@urun.Miktar Adet</td>
                                <td>
                                    @if (urun.Miktar > 10)
                                    {
                                        <span class="badge bg-success">Stokta</span>
                                    }
                                    else if (urun.Miktar > 0)
                                    {

                                        <span class="badge bg-warning text-dark">Azalıyor</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-danger">Tükendi</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <!-- Silme Butonu -->
                                    <form method="post" asp-page-handler="Sil" class="d-inline">
                                        <input type="hidden" name="id" value="@urun.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bu ürünü silmek istediğinize emin misiniz?');">
                                            <i class="fas fa-trash"></i> Sil
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- YENİ ÜRÜN EKLEME PENCERESİ (MODAL) -->
<div class="modal fade" id="urunEkleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Yeni Ürün Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Ekle">
                <div class="modal-body">
                    <div class="mb-3">
                        <label>Ürün Kodu</label>
                        <input type="text" asp-for="YeniUrun.Kodu" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label>Ürün Adı</label>
                        <input type="text" asp-for="YeniUrun.Adi" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label>Kategori</label>
                        <input type="text" asp-for="YeniUrun.Kategori" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label>Miktar</label>
                        <input type="number" asp-for="YeniUrun.Miktar" class="form-control" required min="0" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>