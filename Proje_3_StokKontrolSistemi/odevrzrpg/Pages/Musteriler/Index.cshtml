@page
@model odevrzrpg.Pages.Musteriler.IndexModel
@{
    ViewData["Title"] = "Müşteri Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Müşteri Yönetim Paneli</h2>
        <a class="btn btn-success" href="/Musteriler/Create">Yeni Müşteri Ekle</a>
    </div>

    <table class="table table-striped table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Müşteri No</th>
                <th>Ad Soyad</th>
                <th>Telefon</th>
                <th>E-posta</th>
                <th>Şehir</th>
                <th>Bakiye (TL)</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.listele.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">Henüz kayıtlı müşteri bulunmuyor.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model.listele)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.AdSoyad</td>
                        <td>@item.Telefon</td>
                        <td>@item.Eposta</td>
                        <td>@item.Sehir</td>
                        <td>@item.Bakiye</td>
                        <td>
                            <a class="btn btn-warning btn-sm" href="/Musteriler/Edit?id=@item.Id">Edit</a>
                            <a class="btn btn-danger btn-sm" href="/Musteriler/Delete?id=@item.Id">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>