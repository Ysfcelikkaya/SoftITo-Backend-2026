@page
@model odevrzrpg.Pages.Satislar.CreateModel
@{
    ViewData["Title"] = "Yeni Satış Yap";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2>Yeni Ürün Satışı & Akıllı Stok</h2>
    <p class="text-muted">Müşteriyi ve ürünü seçip adeti girdiğinizde toplam tutar otomatik hesaplanır.</p>

    @if (Model.errorMessage.Length > 0)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Hata:</strong> @Model.errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="POST">
        <div class="mb-3">
            <label class="form-label">Müşteri Seçiniz</label>
            <select class="form-select" name="MusteriAdSoyad" required>
                <option value="">-- Kayıtlı Müşteri Seçiniz --</option>
                @foreach (var musteriAdi in Model.MusteriListesi)
                {
                    <option value="@musteriAdi">@musteriAdi</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Satılacak Ürün</label>
            <select class="form-select" name="UrunAdi" id="urunSelect" onchange="Hesapla()" required>
                <option value="" data-fiyat="0">-- Ürün Seçiniz --</option>
                @foreach (var urun in Model.UrunListesi)
                {
                    <option value="@urun.Key" data-fiyat="@urun.Value">@urun.Key (Birim Fiyatı: @urun.Value TL)</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Satış Adeti</label>
            <input type="number" class="form-control" name="Adet" id="urunAdet" value="1" min="1" oninput="Hesapla()" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Toplam Satış Tutarı (TL)</label>
            <input type="number" step="0.01" class="form-control bg-light" name="ToplamTutar" id="toplamTutar" readonly required>
        </div>

        <button type="submit" class="btn btn-warning fw-bold text-dark">Satışı Onayla ve Stoktan Düş</button>
        <a class="btn btn-outline-secondary" href="/Satislar/Index">İptal</a>
    </form>
</div>

<script>
    function Hesapla() {
        var urunElement = document.getElementById("urunSelect");
        var adetElement = document.getElementById("urunAdet");
        var toplamTutarElement = document.getElementById("toplamTutar");

        var secilenSecenek = urunElement.options[urunElement.selectedIndex];
        var birimFiyat = parseFloat(secilenSecenek.getAttribute("data-fiyat")) || 0;

        var adet = parseInt(adetElement.value) || 0;

        var toplam = birimFiyat * adet;
        toplamTutarElement.value = toplam.toFixed(2);
    }
</script>