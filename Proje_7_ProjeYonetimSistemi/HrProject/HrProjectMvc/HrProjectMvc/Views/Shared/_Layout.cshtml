<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HrProject</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
            body {
                background-color: #f4f6f9;
            }

            .sidebar {
                height: 100vh;
                background: #212529;
                padding: 20px;
            }

                .sidebar a {
                    color: white;
                    display: block;
                    padding: 10px;
                    text-decoration: none;
                    border-radius: 6px;
                }

                    .sidebar a:hover {
                        background: #0d6efd;
                    }

            .content {
                padding: 20px;
            }
    </style>
</head>

<body>

    <div class="container-fluid">
        <div class="row">

            <!-- SIDEBAR -->
            <div class="col-2 sidebar">

                <h4 class="text-white">HR PANEL</h4>

                <hr class="text-white" />

                <a asp-controller="Home" asp-action="Index">Dashboard</a>
                <a asp-controller="Users" asp-action="Index">Users</a>
                <a asp-controller="Roles" asp-action="Index">Roles</a>
                <a asp-controller="Developers" asp-action="Index">Developers</a>
                <a asp-controller="Tasks" asp-action="Index">Tasks</a>
                <a asp-controller="Projects" asp-action="Index">Projects</a>

            </div>

            <!-- CONTENT -->
            <div class="col-10 content">
                @RenderBody()
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>