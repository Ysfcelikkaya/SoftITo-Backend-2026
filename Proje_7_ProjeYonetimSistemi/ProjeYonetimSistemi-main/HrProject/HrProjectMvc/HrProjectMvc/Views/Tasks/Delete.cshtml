@model HrProjectMvc.Models.Tasks

@{
    ViewData["Title"] = "Delete Task";
}

<h1>Delete Task</h1>

<h3>Are you sure you want to delete this?</h3>

<hr />

<dl class="row">

    <dt class="col-sm-2">Task Name</dt>
    <dd class="col-sm-10">@Model.TaskTitle</dd>

    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>

    <dt class="col-sm-2">Project Id</dt>
    <dd class="col-sm-10">@Model.ProjectId</dd>

</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="TaskId" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    |
    <a asp-action="Index">Back to List</a>
</form>