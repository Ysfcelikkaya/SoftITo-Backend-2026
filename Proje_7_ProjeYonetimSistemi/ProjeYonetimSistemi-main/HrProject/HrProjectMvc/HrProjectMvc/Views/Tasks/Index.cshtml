@model IEnumerable<HrProjectMvc.Models.Tasks>

@{
    ViewData["Title"] = "Tasks";
}

<h1>Tasks List</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New Task</a>
</p>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.TaskId)</th>
            <th>@Html.DisplayNameFor(model => model.TaskTitle)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>@Html.DisplayNameFor(model => model.ProjectId)</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.TaskId</td>
            <td>@item.TaskTitle</td>
            <td>@item.Status</td>
            <td>@item.ProjectId</td>

            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.TaskId }, new { @class = "btn btn-primary" }) |
                @Html.ActionLink("Delete", "Delete", new { id = item.TaskId }, new { @class = "btn btn-danger" })
            </td>
        </tr>
}
    </tbody>

</table>