@model AracKiralamaMvc.Models.Kullanici
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body p-5">
                <h3 class="text-center mb-4 fw-bold">Giriş</h3>

                @if (ViewBag.Hata != null)
                {
                    <div class="alert alert-danger text-center">@ViewBag.Hata</div>
                }

                <form asp-action="Login" method="post">
                    <div class="form-group mb-3">
                        <label class="form-label">E-Posta Adresi</label>
                        <input name="Email" type="email" class="form-control" required />
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label">Şifre</label>
                        <input name="Sifre" type="password" class="form-control" required />
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">Giriş Yap</button>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <a asp-action="Register" class="text-decoration-none">Hesabınız yok mu? Kayıt Olun</a>
                </div>
            </div>
        </div>
    </div>
</div>