@model AracKiralamaMvc.Models.Arac

@{
    ViewData["Title"] = "Araç Düzenle";
}

<div class="container mt-4">
    <h2>Araç Düzenle</h2>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Edit">
                <!-- Id değerini gizli olarak tutuyoruz ki güncellerken kaybolmasın -->
                <input type="hidden" asp-for="Id" />

                <div class="form-group mb-3">
                    <label class="control-label">Marka</label>
                    <input asp-for="Marka" class="form-control" required />
                </div>
                <div class="form-group mb-3">
                    <label class="control-label">Model</label>
                    <input asp-for="Model" class="form-control" required />
                </div>
                <div class="form-group mb-3">
                    <label class="control-label">Üretim Yılı</label>
                    <input asp-for="Yil" class="form-control" type="number" required />
                </div>
                <div class="form-group mb-3">
                    <label class="control-label">Günlük Ücret (₺)</label>
                    <input asp-for="GunlukUcret" class="form-control" type="number" step="0.01" required />
                </div>
                <div class="form-group">
                    <input type="submit" value="Güncelle" class="btn btn-primary" />
                    <a asp-action="Index" class="btn btn-secondary ms-2">Listeye Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>