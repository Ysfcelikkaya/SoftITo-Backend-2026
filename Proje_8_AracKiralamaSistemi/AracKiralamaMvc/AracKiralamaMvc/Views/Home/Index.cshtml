@model IEnumerable<AracKiralamaMvc.Models.Kiralama>

@{
    ViewData["Title"] = "Dashboard";
}

<!-- Üst İstatistik Kartları -->
<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card text-white bg-primary h-100 shadow-sm border-0">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-white-50 fw-bold">Toplam Araç</h6>
                <h2 class="mb-0">@ViewBag.ToplamArac</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-white bg-success h-100 shadow-sm border-0">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-white-50 fw-bold">Kayıtlı Müşteri</h6>
                <h2 class="mb-0">@ViewBag.ToplamMusteri</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-dark bg-warning h-100 shadow-sm border-0">
            <div class="card-body">
                <h6 class="card-title text-uppercase fw-bold text-dark" style="opacity:0.7;">Aktif Kiralamalar</h6>
                <h2 class="mb-0">@ViewBag.AktifKiralamalar</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-white bg-danger h-100 shadow-sm border-0">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-white-50 fw-bold">Toplam Gelir</h6>
                <h2 class="mb-0">₺ @ViewBag.ToplamGelir</h2>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Hızlı İşlemler Menüsü -->
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white fw-bold py-3">
                ⚡ Hızlı İşlemler
            </div>
            <div class="card-body">
                <div class="d-grid gap-3">
                    <a asp-controller="Araclar" asp-action="Create" class="btn btn-outline-primary text-start">➕ Yeni Araç Ekle</a>
                    <a asp-controller="Musteriler" asp-action="Create" class="btn btn-outline-success text-start">👤 Yeni Müşteri Ekle</a>
                    <a asp-controller="Kiralamalar" asp-action="Create" class="btn btn-outline-warning text-dark text-start">🔑 Yeni Kiralama Yap</a>
                    <a asp-controller="Odemeler" asp-action="Create" class="btn btn-outline-danger text-start">💳 Yeni Ödeme Al</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Son Yapılan İşlemler Tablosu -->
    <div class="col-md-8 mb-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white fw-bold py-3 d-flex justify-content-between align-items-center">
                Son Kiralamalar
                <a asp-controller="Kiralamalar" asp-action="Index" class="btn btn-sm btn-light">Tümünü Gör</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Müşteri Adı</th>
                                <th>Araç Bilgisi</th>
                                <th>Başlangıç</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var kiralama in Model)
                                {
                                    var durum = kiralama.BitisTarih.Date >= DateTime.Now.Date ? "Devam Ediyor" : "Süresi Doldu";
                                    var badgeRenk = kiralama.BitisTarih.Date >= DateTime.Now.Date ? "bg-success" : "bg-danger";

                                    <tr>
                                        <!-- ID'ler yerine İsimleri yazdırıyoruz -->
                                        <td class="ps-3 fw-bold">@kiralama.AdSoyad</td>
                                        <td>@kiralama.Marka @kiralama.Model</td>

                                        <td>@kiralama.BaslangicTarih.ToShortDateString()</td>
                                        <td><span class="badge @badgeRenk">@durum</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">Henüz hiçbir kiralama yapılmamış.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>