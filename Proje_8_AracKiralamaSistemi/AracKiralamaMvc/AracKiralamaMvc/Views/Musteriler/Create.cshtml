@model AracKiralamaMvc.Models.Musteri

@{
    ViewData["Title"] = "Yeni Müşteri Ekle";
}

<div class="container mt-4">
    <h2>Yeni Müşteri Ekle</h2>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Create">
                <div class="form-group mb-3">
                    <label class="control-label">Ad Soyad</label>
                    <input asp-for="AdSoyad" class="form-control" required />
                </div>
                <div class="form-group mb-3">
                    <label class="control-label">Telefon Numarası</label>
                    <input asp-for="Telefon" class="form-control" required />
                </div>
                <div class="form-group mb-4">
                    <label class="control-label">Ehliyet Numarası</label>
                    <input asp-for="EhliyetNo" class="form-control" required />
                </div>
                <div class="form-group">
                    <input type="submit" value="Kaydet" class="btn btn-success" />
                    <a asp-action="Index" class="btn btn-secondary ms-2">Listeye Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>