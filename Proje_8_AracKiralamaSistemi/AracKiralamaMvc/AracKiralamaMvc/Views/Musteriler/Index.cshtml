@model IEnumerable<AracKiralamaMvc.Models.Musteri>

@{
    ViewData["Title"] = "Müşteri Listesi";
}

<div class="container mt-4">
    <h2>Müşteri Listesi</h2>
    <p>
        <a asp-action="Create" class="btn btn-primary">Yeni Müşteri Ekle</a>
    </p>

    <table class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Ad Soyad</th>
                <th>Telefon</th>
                <th>Ehliyet No</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.AdSoyad</td>
                        <td>@item.Telefon</td>
                        <td>@item.EhliyetNo</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bu müşteriyi silmek istediğinize emin misiniz?');">Sil</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center">Sistemde kayıtlı müşteri bulunamadı.</td>
                </tr>
            }
        </tbody>
    </table>
</div>