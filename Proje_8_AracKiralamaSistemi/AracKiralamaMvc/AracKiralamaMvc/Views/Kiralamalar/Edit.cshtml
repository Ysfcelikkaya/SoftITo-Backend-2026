@model AracKiralamaMvc.Models.Kiralama

@{
    ViewData["Title"] = "Kiralama Düzenle";
}

<div class="container mt-4">
    <h2>Kiralama Düzenle</h2>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />

                <div class="form-group mb-3">
                    <label class="control-label">Araç Seçiniz</label>
                    <select asp-for="AracId" class="form-select" required>
                        <option value="">-- Listeden Araç Seçin --</option>
                        @if (ViewBag.Araclar != null)
                        {
                            foreach (var arac in ViewBag.Araclar)
                            {
                                <option value="@arac.Id">@arac.Marka @arac.Model - (@arac.Yil)</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label">Müşteri Seçiniz</label>
                    <select asp-for="MusteriId" class="form-select" required>
                        <option value="">-- Listeden Müşteri Seçin --</option>
                        @if (ViewBag.Musteriler != null)
                        {
                            foreach (var musteri in ViewBag.Musteriler)
                            {
                                <option value="@musteri.Id">@musteri.AdSoyad</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label">Başlangıç Tarihi</label>
                    <input asp-for="BaslangicTarih" class="form-control" type="date" required />
                </div>

                <div class="form-group mb-4">
                    <label class="control-label">Bitiş Tarihi</label>
                    <input asp-for="BitisTarih" class="form-control" type="date" required />
                </div>

                <div class="form-group">
                    <input type="submit" value="Güncelle" class="btn btn-primary" />
                    <a asp-action="Index" class="btn btn-secondary ms-2">Listeye Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>