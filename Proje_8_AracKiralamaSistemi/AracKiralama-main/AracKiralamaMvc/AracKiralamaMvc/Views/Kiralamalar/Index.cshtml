@model IEnumerable<AracKiralamaMvc.Models.Kiralama>

@{
    ViewData["Title"] = "Kiralama Listesi";
}

<div class="container mt-4">
    <h2>Kiralama Listesi</h2>
    <p>
        <a asp-action="Create" class="btn btn-primary">Yeni Kiralama Yap</a>
    </p>

    <table id="exportTablosu" class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Araç Bilgisi</th>
                <th>Müşteri Adı</th>
                <th>Başlangıç Tarihi</th>
                <th>Bitiş Tarihi</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-bold">@item.Marka @item.Model</td>
                        <td class="fw-bold">@item.AdSoyad</td>
                        <td>@item.BaslangicTarih.ToShortDateString()</td>
                        <td>@item.BitisTarih.ToShortDateString()</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bu kiralama kaydını silmek istediğinize emin misiniz?');">Sil</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">Sistemde kiralama kaydı bulunamadı.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

    <script>
        $(document).ready(function() {
        $('#exportTablosu').DataTable({
        dom: 'Bfrtip',
        buttons: [
        { extend: 'excelHtml5', text: '📊 Excel İndir', className: 'btn btn-success btn-sm' },
        { extend: 'pdfHtml5', text: '📄 PDF İndir', className: 'btn btn-danger btn-sm' }
        ],
        language: {
        url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json'
        }
        });
        });
    </script>
}