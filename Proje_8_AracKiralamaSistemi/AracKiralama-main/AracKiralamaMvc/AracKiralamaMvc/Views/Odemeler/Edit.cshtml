@model AracKiralamaMvc.Models.Odeme

@{
    ViewData["Title"] = "Ödeme Düzenle";
}

<div class="container mt-4">
    <h2>Ödeme Düzenle</h2>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                <div class="form-group mb-3">
                    <label class="control-label">Kiralama Id</label>
                    <input asp-for="KiralamaId" class="form-control" type="number" required />
                </div>
                <div class="form-group mb-3">
                    <label class="control-label">Tutar (₺)</label>
                    <input asp-for="Tutar" class="form-control" type="number" step="0.01" required />
                </div>
                <div class="form-group mb-4">
                    <label class="control-label">Ödeme Tarihi</label>
                    <input asp-for="OdemeTarihi" class="form-control" type="date" required />
                </div>
                <div class="form-group">
                    <input type="submit" value="Güncelle" class="btn btn-primary" />
                    <a asp-action="Index" class="btn btn-secondary ms-2">Listeye Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>