<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Araç Kiralama Sistemi</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
            body {
                font-family: 'Inter', sans-serif;
                background-color: #f8f9fa; 
            }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    🚗 RENT A CAR
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Araclar" asp-action="Index">Araçlar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Musteriler" asp-action="Index">Müşteriler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Kiralamalar" asp-action="Index">Kiralamalar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Odemeler" asp-action="Index">Ödemeler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-danger fw-bold" asp-controller="Auth" asp-action="Logout">🚪 Çıkış Yap</a>
                        </li>
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Login">Giriş Yap</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm mt-1 ms-2 px-3" asp-controller="Auth" asp-action="Register">Kayıt Ol</a>
                            </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-5 mb-5 flex-grow-1">
        <main role="main" class="pb-3 bg-white p-5 rounded-4 shadow-sm border">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white py-3 mt-auto shadow-sm">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - Araç Kiralama Otomasyonu - <span class="text-primary">Admin Paneli</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>