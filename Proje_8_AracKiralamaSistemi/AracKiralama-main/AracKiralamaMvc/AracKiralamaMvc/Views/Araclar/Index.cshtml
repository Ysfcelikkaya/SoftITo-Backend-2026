@model IEnumerable<AracKiralamaMvc.Models.Arac>

@{
    ViewData["Title"] = "Araç Listesi";
}

<div class="container mt-4">
    <h2>Araç Listesi</h2>
    <p>
        <a asp-action="Create" class="btn btn-primary">Yeni Araç Ekle</a>
    </p>

    <table class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Marka</th>
                <th>Model</th>
                <th>Yıl</th>
                <th>Günlük Ücret</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Marka</td>
                        <td>@item.Model</td>
                        <td>@item.Yil</td>
                        <td>@item.GunlukUcret ₺</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bu aracı silmek istediğinize emin misiniz?');">Sil</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">Sistemde kayıtlı araç bulunamadı.</td>
                </tr>
            }
        </tbody>
    </table>
</div>