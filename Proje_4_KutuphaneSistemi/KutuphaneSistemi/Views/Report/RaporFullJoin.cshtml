@model List<Kutuphane.Model.viewModel.kitkatlistview>

@{
    ViewData["Title"] = "Eksiksiz Tüm Veriler Raporu (Full Join)";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-danger text-white">
            <h3 class="card-title mb-0">🌐 Evrensel Kitap & Kategori Raporu (Full Join)</h3>
        </div>
        <hr />

        <div class="d-flex justify-content-center gap-2 mb-4 flex-wrap">
            <a asp-controller="Report" asp-action="Index" class="btn btn-outline-secondary">Standart Rapor</a>
            <a asp-controller="Report" asp-action="RaporInnerJoin" class="btn btn-outline-primary">Inner Join</a>
            <a asp-controller="Report" asp-action="RaporLeftJoin" class="btn btn-outline-warning text-dark">Left Join</a>
            <a asp-controller="Report" asp-action="RaporGroupBy" class="btn btn-outline-info">Group By</a>
            <a asp-controller="Report" asp-action="RaporFullJoin" class="btn btn-outline-danger">Full Join</a>
            <a asp-controller="Report" asp-action="RaporAyniKitapSayisi" class="btn btn-dark shadow">Aynı Sayıdakiler (Özel)</a>
        </div>
        <div class="card-body">
            <p class="text-muted">Bu raporda veritabanındaki her şey listelenir: Kategorisi olmayan kitaplar ve içinde hiç kitap bulunmayan boş kategoriler bir aradadır.</p>
            
            <table class="table table-bordered table-striped table-hover mt-3">
                <thead class="table-dark">
                    <tr>
                        <th>Kitap Adı </th>
                        <th>Kitap Sayısı</th>
                        <th>Kategori Adı </th>
                        <th>Yazar Adı </th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (item.KitapAdi == "Bu Kategoride Henüz Kitap Yok")
                                    {
                                        <span class="text-muted fst-italic">❌ @item.KitapAdi</span>
                                    }
                                    else
                                    {
                                        <span class="fw-bold">@item.KitapAdi</span>
                                    }
                                </td>
                                <td>
                                    @if (item.KitapSayisi == 0)
                                    {
                                        <span class="badge bg-danger">0 Adet</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@item.KitapSayisi Adet</span>
                                    }
                                </td>
                                <td>
                                    @if (item.KategoriAdi == "Kategori Atanmamış Kitap")
                                    {
                                        <span class="text-warning fw-semibold">⚠️ @item.KategoriAdi</span>
                                    }
                                    else
                                    {
                                        <span>@item.KategoriAdi</span>
                                    }
                                </td>
                                <td>
                                    @if (item.YazarAdi == "Yazar Atanmamış Kitap")
                                    {
                                        <span class="text-warning fw-semibold">⚠️ @item.YazarAdi</span>
                                    }
                                    else
                                    {
                                        <span>@item.YazarAdi</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-danger fw-bold">Veritabanında hiçbir kayıt bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>