@model List<Kutuphane.Model.viewModel.kitkatlistview>

@{
    ViewData["Title"] = "Kategori Bazlı Kitap İstatistikleri (Group By)";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark fw-bold">
            <h3 class="card-title mb-0">📊 Kategori İstatistik Raporu (Group By)</h3>
        </div>
        <hr />

        <div class="d-flex justify-content-center gap-2 mb-4 flex-wrap">
            <a asp-controller="Report" asp-action="Index" class="btn btn-outline-secondary">Standart Rapor</a>
            <a asp-controller="Report" asp-action="RaporInnerJoin" class="btn btn-outline-primary">Inner Join</a>
            <a asp-controller="Report" asp-action="RaporLeftJoin" class="btn btn-outline-warning text-dark">Left Join</a>
            <a asp-controller="Report" asp-action="RaporGroupBy" class="btn btn-outline-info">Group By</a>
            <a asp-controller="Report" asp-action="RaporFullJoin" class="btn btn-outline-danger">Full Join</a>
            <a asp-controller="Report" asp-action="RaporAyniKitapSayisi" class="btn btn-dark shadow">Aynı Sayıdakiler (Özel)</a>
        </div>
        <div class="card-body">
            <p class="text-muted">Bu raporda kitaplar kategorilerine göre kümelenmiş ve kategori başına toplam stok miktarları hesaplanmıştır.</p>
            
            <table class="table table-bordered table-hover mt-3">
                <thead class="table-dark">
                    <tr>
                        <th>Kategori Adı</th>
                        <th>Kategoriye Ait Çeşit Sayısı</th>
                        <th>Toplam Kitap Adedi (Stok)</th>
                        <th>Yazar Adı</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@item.KategoriAdi</td>
                                <td><span class="badge bg-info text-dark">@item.KitapAdi</span></td>
                                <td><span class="badge bg-success">@item.KitapSayisi Adet Toplam</span></td>
                                <td><span class="badge bg-info text-dark">@item.YazarAdi</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-danger fw-bold">Gruplanacak veri bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
