@model Kutuphane.Model.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Kütüphane Giriş</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-secondary bg-opacity-25">
    <div class="container d-flex justify-content-center align-items-center" style="height:100vh;">
        <div class="card shadow-lg p-4 border-0 rounded-3" style="width:380px;">
            <div class="text-center mb-4">
                <i class="fas fa-book-reader fa-3x text-primary mb-2"></i>
                <h3 class="fw-bold">Kütüphane Giriş</h3>
            </div>

            <form method="post" asp-controller="Account" asp-action="Login">
                <div class="mb-3">
                    <label class="form-label text-muted fw-bold">Kullanıcı Adı</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-user"></i></span>
                        <input name="Username" class="form-control border-start-0" type="text" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted fw-bold">Şifre</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-lock"></i></span>
                        <input name="Password" class="form-control border-start-0" type="password" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 fw-bold py-2 mt-2">
                    <i class="fas fa-sign-in-alt me-2"></i>Giriş Yap
                </button>

                <!-- Hata Mesajı Viewbag üzerinden gelir -->
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger mt-3 text-center small">
                        <i class="fas fa-exclamation-circle me-1"></i> @ViewBag.ErrorMessage
                    </div>
                }

                <div class="text-center mt-4 pt-3 border-top">
                    <span class="text-muted">Okuyucu kaydınız yok mu?</span><br />
                    <a href="/Account/Register" class="text-decoration-none fw-bold mt-1 d-inline-block">Hemen Kayıt Ol</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>