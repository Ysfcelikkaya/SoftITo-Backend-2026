@model Kutuphane.Model.Kitap

@{
    ViewData["Title"] = "Delete";
}

<h1>Kitap Silme Sayfası</h1>

<h3>Bu kitabı silmek isteiğinize emin misiniz?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.KitapAdi)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.KitapAdi)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.KitapSayisi)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.KitapSayisi)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="KitapNo" />

        <input type="hidden" asp-for="KitapAdi" />
        <input type="hidden" asp-for="KitapSayisi" />
        <input type="hidden" asp-for="KategoriNo" />
        <input type="hidden" asp-for="YazarNo" />

        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>