<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kütüphane Admin</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            body {
                background: #f4f6f9;
            }

            .sidebar {
                width: 260px;
                height: 100vh;
                position: fixed;
                top: 0;
                left: 0;
                background: #1f2937;
                padding-top: 20px;
            }

                .sidebar a {
                    display: block;
                    color: #cbd5e1;
                    padding: 12px 20px;
                    text-decoration: none;
                    transition: 0.2s;
                }

                    .sidebar a:hover {
                        background: #374151;
                        color: #fff;
                    }

            .topbar {
                height: 60px;
                background: #fff;
                margin-left: 260px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 20px;
                border-bottom: 1px solid #ddd;
            }

            .content {
                margin-left: 260px;
                padding: 20px;
            }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h4 class="text-white text-center mb-4"><i class="bi bi-book-half me-2"></i>KÜTÜPHANE</h4>

        <a asp-controller="Home" asp-action="Index">
            <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </a>

        <a asp-controller="Kitap" asp-action="Index">
            <i class="bi bi-book me-2"></i> Kitaplar
        </a>

        <a asp-controller="Yazar" asp-action="Index">
            <i class="bi bi-person me-2"></i> Yazarlar
        </a>

        <a asp-controller="Kategori" asp-action="Index">
            <i class="bi bi-tags me-2"></i> Kategoriler
        </a>

        <hr class="text-white">

        <a asp-controller="Kitap" asp-action="ExportToPdf">
            <i class="bi bi-file-earmark-pdf me-2"></i> PDF Rapor
        </a>

        <a asp-controller="Kitap" asp-action="ExportToExcel">
            <i class="bi bi-file-earmark-excel me-2"></i> Excel Rapor
        </a>
    </div>

    <!-- TOPBAR -->
    <div class="topbar shadow-sm">
        <div>
            <span class="fw-bold fs-5 text-secondary">@ViewData["Title"]</span>
        </div>

        <div class="d-flex align-items-center gap-3">
            <!-- Kullanıcı Profili Gösterimi -->
            <div class="d-flex align-items-center text-secondary">
                <i class="bi bi-person-circle fs-4 me-2"></i>
                <span class="fw-bold">Yönetici</span>
            </div>

            <!-- ÇIKIŞ YAP BUTONU EKLENDİ -->
            <a href="/Account/Login" class="btn btn-sm btn-outline-danger fw-bold">
                <i class="bi bi-box-arrow-right me-1"></i> Çıkış Yap
            </a>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>