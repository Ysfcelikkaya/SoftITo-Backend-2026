@model IEnumerable<Kutuphane.Model.viewModel.kitkatlistview>
@{
    ViewData["Title"] = "Raporlar";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">📚 Gelişmiş Kütüphane Raporlama Modülü</h2>
    <hr />

    <div class="d-flex justify-content-center gap-2 mb-4 flex-wrap">
        <a asp-controller="Report" asp-action="Index" class="btn btn-secondary">Standart Rapor (Kitap-Kat)</a>
        <a asp-controller="Report" asp-action="RaporInnerJoin" class="btn btn-primary">Inner Join (Kitap-Kat-Yazar)</a>
        <a asp-controller="Report" asp-action="RaporLeftJoin" class="btn btn-warning text-dark">Left Join (Tüm Kitaplar)</a>
        <a asp-controller="Report" asp-action="RaporGroupBy" class="btn btn-info text-white">Group By (Kategori Özet)</a>
        <a asp-controller="Report" asp-action="RaporFullJoin" class="btn btn-danger">Full Join (Tüm Evren)</a>
        <a asp-controller="Report" asp-action="RaporAyniKitapSayisi" class="btn btn-outline-dark">Aynı Sayıdakiler</a>

    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0">Standart Rapor Verileri</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-bordered table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Kitap Adı</th>
                        <th>Kitap Sayısı (Stok)</th>
                        <th>Kategori Adı</th>
                        <th>Yazar Adı</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.KitapAdi</td>
                                <td>@item.KitapSayisi</td>
                                <td>@item.KategoriAdi</td>
                                <th>@item.YazarAdi</th>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">Gösterilecek rapor kaydı bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>